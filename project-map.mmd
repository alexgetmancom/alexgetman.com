flowchart LR
  subgraph Authoring["How a post enters the system"]
    ControlBot["Telegram control bot\ncreate/edit/schedule"]
    MCP["MCP adapter\nagent commands"]
    CommandCenter["Private Command Center\nweb Studio + operations"]
  end

  subgraph Core["Durable application core"]
    Studio["Studio services\nowner checks + commands"]
    Content["Content\ndrafts, text, translations, assets"]
    Publishing["Publishing\nplans, targets, jobs, retries"]
    Profiles["Platform profiles\nlimits, media rules, credentials"]
    Analytics["Analytics\nmetrics and creator snapshots"]
    Operations["Operations\nstatus, doctor, audit, verify"]
    DB[("SQLite\nsource of truth")]
  end

  subgraph Workers["Background work"]
    Crosspost["Crosspost worker\ntext + media jobs"]
    VideoWorker["Video worker\nprepare + publish video"]
    SiteWorker["Site worker\nfeeds, assets, content index"]
    Delivery["Delivery ports\nmedia preparation + API calls"]
  end

  subgraph Destinations["Publication destinations"]
    PublicSite["Public Astro site\nfeeds, search, pages"]
    TelegramChannel["Telegram channel\nand Telegram Stories"]
    SocialText["Threads · Facebook\nX · Bluesky"]
    VideoPlatforms["YouTube Shorts\nInstagram Reels / Stories"]
  end

  subgraph Deploy["Production"]
    CI["GitHub Actions"] --> Agent["Host deploy agent\nimmutable image + rollback"]
    Agent --> Runtime["Backend + Astro containers"]
  end

  ControlBot --> Studio
  MCP --> Studio
  CommandCenter --> Studio
  CommandCenter --> Operations
  Studio --> Content
  Studio --> Publishing
  Studio --> Analytics
  Profiles --> Publishing
  Profiles --> Delivery
  Content <--> DB
  Publishing <--> DB
  Analytics <--> DB
  Operations <--> DB
  DB --> Crosspost
  DB --> VideoWorker
  DB --> SiteWorker
  Crosspost --> Delivery
  VideoWorker --> Delivery
  Delivery --> TelegramChannel
  Delivery --> SocialText
  Delivery --> PublishingSites
  Delivery --> VideoPlatforms
  SiteWorker --> PublicSite
  Runtime --> ControlBot
