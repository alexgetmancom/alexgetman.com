{
  "name": "alexgetman-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "bun scripts/generate-responsive-images.ts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun run --filter @alexgetman/shared typecheck && bun run --filter @alexgetman/backend typecheck",
    "test": "bun run --filter @alexgetman/backend test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "knip": "bun tools/knip/node_modules/.bin/knip --config knip.json",
    "check:web": "bun run build",
    "check:backend": "bun run --filter @alexgetman/backend check",
    "check:language": "tsx scripts/enforce-typescript.ts",
    "check:all": "tsx scripts/check-all.ts",
    "sync:production-web": "tsx scripts/web-sync.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.2",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@types/sanitize-html": "^2.16.1",
    "@biomejs/biome": "^2.0.6",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.23.0",
    "typescript": "7.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx biome check --staged --no-errors-on-unmatched"
  }
}
