{
  "name": "alexgetman-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "dev": "astro dev",
    "build": "bun scripts/generate-responsive-images.ts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun run --filter @alexgetman/backend typecheck",
    "test": "bun run --filter @alexgetman/backend test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "knip": "bun tools/knip/node_modules/.bin/knip --config knip.json",
    "deps:check": "taze",
    "check:web": "bun run build",
    "check:backend": "bun run --filter @alexgetman/backend check",
    "check:language": "bun scripts/enforce-typescript.ts",
    "check:all": "bun scripts/check-all.ts",
    "sync:production-web": "bun scripts/web-sync.ts"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@mtcute/bun": "^0.30.3",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "lefthook": "^2.1.10",
    "sharp": "^0.35.3",
    "taze": "^19.14.1",
    "typescript": "7.0.2"
  }
}
