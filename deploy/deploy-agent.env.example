# This file belongs on the host at /etc/alexgetman/deploy-agent.env and must be chmod 600.
DEPLOY_AGENT_TOKEN=
DEPLOY_AGENT_HOST=172.17.0.1
DEPLOY_AGENT_PORT=9899
DEPLOY_IMAGE_REPOSITORY=ghcr.io/alexgetmancom/alexgetman-backend

# One independent, immutable deployment state per runtime. Each target has its
# own compose manifest, image env file, health endpoint and rollback history.
DEPLOY_TARGETS_JSON={"alex":{"composeFile":"/home/deploy/alexgetman-runtime/compose.yaml","imageEnvFile":"/home/deploy/alexgetman-runtime/deploy-image.env","stateFile":"/var/lib/alexgetman-deploy/alex.json","healthUrl":"http://127.0.0.1:8788/readyz","container":"alexgetman-backend"},"maru":{"composeFile":"/home/deploy/maru/maru.compose.yaml","imageEnvFile":"/home/deploy/maru/deploy-image.env","stateFile":"/var/lib/alexgetman-deploy/maru.json","healthUrl":"http://127.0.0.1:8789/readyz","container":"maru-backend"}}

# Reuse the controller bot only for deployment notifications. The bot callback is
# authenticated again by grammY against CONTROLLER_ADMIN_IDS before the app calls this agent.
DEPLOY_NOTIFICATION_BOT_TOKEN=
DEPLOY_NOTIFICATION_CHAT_ID=
DEPLOY_NOTIFICATION_API_BASE_URL=http://127.0.0.1:8081
