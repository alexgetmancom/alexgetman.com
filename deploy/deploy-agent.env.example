# This file belongs on the host at /etc/alexgetman/deploy-agent.env and must be chmod 600.
DEPLOY_AGENT_TOKEN=
DEPLOY_AGENT_HOST=172.17.0.1
DEPLOY_AGENT_PORT=9899
DEPLOY_COMPOSE_FILE=/home/deploy/alexgetman-runtime/compose.yaml
DEPLOY_IMAGE_ENV_FILE=/home/deploy/alexgetman-runtime/deploy-image.env
DEPLOY_STATE_FILE=/var/lib/alexgetman-deploy/state.json
DEPLOY_HEALTH_URL=http://127.0.0.1:8788/readyz
DEPLOY_CONTAINER_NAME=alexgetman-backend
DEPLOY_IMAGE_REPOSITORY=ghcr.io/alexgetmancom/alexgetman-backend

# Reuse the controller bot only for deployment notifications. The bot callback is
# authenticated again by grammY against CONTROLLER_ADMIN_IDS before the app calls this agent.
DEPLOY_NOTIFICATION_BOT_TOKEN=
DEPLOY_NOTIFICATION_CHAT_ID=
DEPLOY_NOTIFICATION_API_BASE_URL=http://127.0.0.1:8081
