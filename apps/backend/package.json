{
  "name": "@alexgetman/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/src/index.js",
    "ops": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@alexgetman/shared": "file:../../packages/shared",
    "@hono/node-server": "^1.17.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.3",
    "grammy": "^1.36.3",
    "hono": "^4.8.5",
    "telegram": "2.26.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
