{
  "name": "@alexgetman/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch ../../apps/web/server.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun --splitting --minify --sourcemap=external",
    "start": "bun --smol ../../apps/web/server.ts",
    "ops": "bun src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/*.test.ts",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@mtcute/bun": "^0.31.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "grammy": "^1.45.1",
    "hono": "^4.12.31",
    "oauth-1.0a": "^2.2.6",
    "p-limit": "^7.3.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  }
}
