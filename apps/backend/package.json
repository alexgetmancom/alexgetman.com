{
  "name": "@alexgetman/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts src/runtime/buildSite.ts src/site/builder.ts src/cli.ts --outdir dist --target bun --splitting --minify --sourcemap=external",
    "start": "bun --smol dist/index.js",
    "ops": "bun src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun --bun vitest run tests/*.test.ts --pool=forks --maxWorkers=4",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "hono": "^4.12.29",
    "p-limit": "^7.3.0",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
