{
  "name": "@alexgetman/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts src/runtime/buildSite.ts src/cli.ts --outdir dist --target bun --splitting --minify --sourcemap=external",
    "start": "bun --smol dist/index.js",
    "ops": "bun src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun scripts/run-tests.ts",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@alexgetman/shared": "file:../../packages/shared",
    "@hono/node-server": "^1.17.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.3",
    "grammy": "^1.36.3",
    "hono": "^4.8.5",
    "telegram": "2.26.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "7.0.2",
    "vitest": "^3.2.4"
  }
}
