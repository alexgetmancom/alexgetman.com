---
import type { HomePost, StoryUi } from "./types";

interface Props {
  activePost: HomePost;
  posts: HomePost[];
  ui: StoryUi;
}

const { activePost, posts, ui } = Astro.props;
const publicSrc = (value?: string | null) => (value ? `/${String(value).replace(/^\/+/, "")}` : undefined);
---

<div class="story-visual-wrap">
  <article class={`story-visual${activePost.image ? '' : ' story-visual--no-image'}`} data-story-visual>
    <span class="story-visual-progress" aria-hidden="true">
      <i data-story-current-progress></i>
    </span>
    <a class="story-visual__link" href={activePost.url} aria-label={activePost.title} data-story-card-link>
      {activePost.image ? (
        <>
          <img
            src={activePost.mediaType === 'video' ? '' : publicSrc(activePost.image)}
            srcset={activePost.mediaType === 'video' ? undefined : activePost.imageSrcSet}
            alt={activePost.title}
            loading="eager"
            decoding="async"
            sizes="(max-width: 760px) min(100vw - 2rem, 390px), 320px"
            hidden={activePost.mediaType === 'video'}
            data-story-image
            data-fallback-src={publicSrc(activePost.fallbackImage)}
          />
          <video
            src={activePost.mediaType === 'video' ? publicSrc(activePost.image) : ''}
            poster={publicSrc(activePost.fallbackImage)}
            muted
            loop
            autoplay
            playsinline
            preload="metadata"
            hidden={activePost.mediaType !== 'video'}
            data-story-video
            data-fallback-src={publicSrc(activePost.fallbackImage)}
          ></video>
        </>
      ) : (
        <span class="story-visual__fallback" data-story-fallback>{activePost.title}</span>
      )}
    </a>
    <button class="audio-chip" type="button" data-audio-toggle aria-pressed="true" aria-label={ui.muted}>
      <span aria-hidden="true">♪</span>
      <span data-audio-label>{ui.muted}</span>
    </button>
    <div class="story-mobile-caption" aria-hidden="true">
      <span data-story-mobile-kicker>{activePost.category}</span>
      <strong data-story-mobile-title>{activePost.title}</strong>
    </div>
    <div class="story-mobile-actions" aria-label={ui.storyLabel}>
      <button class="story-action story-action--primary" type="button" data-story-discuss>
        <span>{ui.discuss}</span>
      </button>
      <button class="story-action" type="button" data-story-share>
        <span>{ui.share}</span>
      </button>
    </div>
    <audio preload="none" data-story-audio></audio>
  </article>
</div>
