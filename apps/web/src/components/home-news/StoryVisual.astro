---
import type { HomePost, StoryUi } from "./types";

interface Props {
  activePost: HomePost;
  posts: HomePost[];
  ui: StoryUi;
}

const { activePost, posts, ui } = Astro.props;
const publicSrc = (value?: string | null) => (value ? `/${String(value).replace(/^\/+/, "")}` : undefined);
const gallery = activePost.gallery || [];
---

{activePost.mediaType !== 'video' && activePost.image && (
  <link rel="preload" as="image" href={publicSrc(activePost.image)} imagesrcset={activePost.imageSrcSet} imagesizes="(max-width: 760px) min(100vw - 2rem, 390px), 320px" fetchpriority="high" />
)}
{activePost.mediaType === 'video' && (activePost.posterSrc || activePost.fallbackImage) && (
  <link rel="preload" as="image" href={publicSrc(activePost.posterSrc || activePost.fallbackImage)} fetchpriority="high" />
)}
<div class="story-visual-wrap">
  <article class={`story-visual${activePost.image ? '' : ' story-visual--no-image'}`} data-story-visual>
    <span class="story-visual-progress" aria-hidden="true">
      <i data-story-current-progress></i>
    </span>
    <a class="story-visual__link" href={activePost.url} aria-label={activePost.title} data-story-card-link>
      <img
        src={activePost.mediaType === 'video' ? undefined : publicSrc(activePost.image)}
        srcset={activePost.mediaType === 'video' ? undefined : activePost.imageSrcSet}
        alt={activePost.title}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        sizes="(max-width: 760px) min(100vw - 2rem, 390px), 320px"
        hidden={!activePost.image || activePost.mediaType === 'video'}
        data-story-image
        data-fallback-src={publicSrc(activePost.fallbackImage)}
      />
      <video
        src={activePost.mediaType === 'video' ? publicSrc(activePost.image) : undefined}
        poster={publicSrc(activePost.posterSrc || activePost.fallbackImage)}
        muted
        autoplay
        playsinline
        preload="metadata"
        hidden={!activePost.image || activePost.mediaType !== 'video'}
        data-story-video
        data-fallback-src={publicSrc(activePost.fallbackImage)}
      ></video>
      <span class="story-visual__fallback" data-story-fallback hidden={!!activePost.image}>{activePost.title}</span>
    </a>
    <div class="story-media-gallery" aria-label="Post media" data-story-gallery hidden={gallery.length < 2}>
      {gallery.map((media, index) => (
        <a href={publicSrc(media.path)} target="_blank" rel="noopener noreferrer" data-story-gallery-item>
          <img src={publicSrc(media.type === "video" ? media.poster || media.path : media.path)} alt={`${activePost.title} — ${index + 1}`} loading="lazy" />
        </a>
      ))}
    </div>
    <button class="audio-chip" type="button" data-audio-toggle aria-pressed="true" aria-label={ui.muted}>
      <span aria-hidden="true">♪</span>
      <span data-audio-label>{ui.muted}</span>
    </button>
    <button class="story-read-trigger" type="button" data-story-read aria-expanded="false">
      <svg viewBox="0 0 24 24" width="23" height="23" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <path d="M14 2v6h6"></path>
        <path d="M8 13h8"></path>
        <path d="M8 17h6"></path>
      </svg>
      <span>{ui.read}</span>
    </button>
    <div class="story-mobile-caption" aria-hidden="true">
      <span data-story-mobile-kicker>{activePost.category}</span>
      <strong data-story-mobile-title>{activePost.title}</strong>
    </div>
    <div class="story-mobile-actions" aria-label={ui.storyLabel}>
      <button class="story-action story-action--primary" type="button" data-story-discuss>
        <span>{ui.discuss}</span>
      </button>
      <button class="story-action" type="button" data-story-share>
        <span>{ui.share}</span>
      </button>
    </div>
    <audio preload="none" data-story-audio></audio>
  </article>
</div>
