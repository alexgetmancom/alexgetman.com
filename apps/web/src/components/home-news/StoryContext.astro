---
import type { HomePost, StoryUi } from "./types";

interface Props {
  activePost: HomePost;
  paragraphs: string[];
  ui: StoryUi;
}

const { activePost, paragraphs } = Astro.props;

const wordsCount = paragraphs.join(" ").split(/\s+/).length;
const readingTimeMin = Math.max(1, Math.ceil(wordsCount / 180));
---

<aside class="story-context" data-story-context>
  <div class="story-panel is-active" data-panel="post">
    <div class="story-category-wrap">
      <span class="story-category-badge" data-story-kicker>{activePost.category}</span>
    </div>
    <h1 data-story-title>{activePost.title}</h1>
    <div class="story-meta">
      <span class="story-meta-item" data-story-reading-time>⏱️ {readingTimeMin} min</span>
      <span class="story-meta-dot">•</span>
      <span class="story-meta-item" data-story-time>{activePost.relativeDate}</span>
      <span class="story-meta-dot">•</span>
      <span class="story-meta-item">👁️ <span data-story-views>{activePost.views || '0'}</span></span>
    </div>
    <div class="story-copy" data-story-copy>
      {paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
    <button class="read-more-button" type="button" data-story-read-more hidden>{ui.readMore}</button>
    <div class="story-panel story-panel--discussion" data-panel="discussion" hidden>
      <div class="story-discussion-frame" data-story-discussion-frame></div>
    </div>
  </div>
</aside>
