---
import { truncateText } from "../../utils/text";
import type { HomePost, StoryUi } from "./types";

interface Props {
  posts: HomePost[];
  ui: StoryUi;
}

const { posts, ui } = Astro.props;
const publicSrc = (value?: string | null) => (value ? `/${String(value).replace(/^\/+/, "")}` : undefined);
---

<nav class="story-rail" aria-label={ui.storyRail}>
  {posts.map((post, index) => (
    <a
      href={post.url}
      class={`rail-card${index === 0 ? ' is-active' : ''}${post.image ? '' : ' rail-card--no-image'}`}
      data-story-index={index}
      data-media-src={publicSrc(post.image)}
      data-media-type={post.mediaType || undefined}
      data-media-fallback={publicSrc(post.fallbackImage)}
      data-media-srcset={post.imageSrcSet || undefined}
    >
      <span class="rail-card__media" aria-hidden="true">
        {post.image ? (
          post.mediaType === 'video' ? (
            post.fallbackImage ? (
              <img
                src={publicSrc(post.fallbackImage)}
                alt={post.title}
                loading={index < 4 ? 'eager' : 'lazy'}
                decoding="async"
                sizes="(max-width: 760px) 38vw, 140px"
              />
            ) : (
              <video
                src={`${publicSrc(post.image)}#t=0.001`}
                muted
                playsinline
                preload="metadata"
              ></video>
            )
          ) : (
            <img
              src={publicSrc(post.image)}
              srcset={post.imageSrcSet}
              alt={post.title}
              loading={index < 4 ? 'eager' : 'lazy'}
              decoding="async"
              sizes="(max-width: 760px) 38vw, 140px"
              data-fallback-src={publicSrc(post.fallbackImage)}
            />
          )
        ) : (
          <span>{post.category}</span>
        )}
      </span>
      <span class="rail-card__shade"></span>
      <span class="rail-card__text">
        <strong>{truncateText(post.title, 62)}</strong>
      </span>
    </a>
  ))}
</nav>
