---
interface Props {
  target: string;
  title?: string;
  message?: string;
  lang?: string;
}

const {
  target,
  title = 'Moved',
  message = 'This page moved to the main news player.',
  lang = 'en'
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={`https://alexgetman.com${target}`} />
    <title>{title}</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #080b10;
        color: #f3f6fa;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      main {
        width: min(520px, calc(100vw - 32px));
      }

      a {
        color: #60a5fa;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>{message}</p>
      <a href={target}>Open</a>
    </main>
  </body>
</html>
