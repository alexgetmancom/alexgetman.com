---
import StoryContext from "./home-news/StoryContext.astro";
import StoryRail from "./home-news/StoryRail.astro";
import StoryVisual from "./home-news/StoryVisual.astro";
import { metricValue, paragraphsFor } from "./home-news/storyHelpers";
import "../styles/home-news-page.css";
import type { HomeLabels, HomePost } from "./home-news/types";

interface Props {
  posts: HomePost[];
  labels: HomeLabels;
  locale: "en" | "ru";
  initialPostId?: number | string;
  initialPaused?: boolean;
}

const { posts, labels, locale, initialPostId, initialPaused = false } = Astro.props;

const selectedPost = initialPostId ? posts.find((post) => String(post.id) === String(initialPostId)) : null;
const storyPosts = selectedPost ? [selectedPost, ...posts.filter((post) => String(post.id) !== String(selectedPost.id))] : posts;
const activePost = storyPosts[0] || null;
const isRu = locale === "ru";
const watchedCutoff =
  [...storyPosts].map((post) => post.views || 0).sort((a, b) => b - a)[Math.min(7, Math.max(0, storyPosts.length - 1))] || 0;
const fullTextFor = (post: HomePost) =>
  (post.body || post.excerpt || post.title)
    .split(/\n+/)
    .map((line) => line.trim())
    .filter(Boolean);
const feedModesFor = (post: HomePost) => {
  const text = fullTextFor(post).join(" ");
  const modes = ["latest"];
  if (text.length >= 700 || fullTextFor(post).length >= 4) modes.push("deep");
  if ((post.views || 0) >= watchedCutoff && watchedCutoff > 0) modes.push("watched");
  return modes;
};
const publicSrc = (value?: string | null) => (value ? `/${String(value).replace(/^\/+/, "")}` : null);
const safeJsonForScript = (value: unknown) =>
  JSON.stringify(value).replace(/</g, "\\u003c").replace(/>/g, "\\u003e").replace(/&/g, "\\u0026");
const ambientSrc = activePost ? publicSrc(activePost.fallbackImage || (activePost.mediaType === "video" ? null : activePost.image)) : null;
const ui = {
  storyLabel: isRu ? "Новостной плеер" : "AI news player",
  discuss: isRu ? "Обсудить" : "Discuss",
  share: isRu ? "Поделиться" : "Share",
  copied: isRu ? "Скопировано" : "Copied",
  backToPost: isRu ? "К посту" : "Back to post",
  readMore: isRu ? "Читать дальше" : "Read more",
  collapse: isRu ? "Свернуть" : "Collapse",
  mute: isRu ? "Звук" : "Sound on",
  muted: isRu ? "Включить звук" : "Tap for sound",
  storyRail: isRu ? "Выбор новостей" : "Story rail",
  feedMode: isRu ? "Режим ленты" : "Feed mode",
  feedLatest: isRu ? "Свежее" : "Latest",
  feedDeep: isRu ? "Лонгриды" : "Deep dives",
  feedWatched: isRu ? "Популярное" : "Popular",
  menu: isRu ? "Меню" : "Menu",
  language: isRu ? "English" : "Русский",
  telegram: "Telegram",
};
---

<main class="home-page">
  {activePost ? (
    <section class="story-player" aria-label={ui.storyLabel} data-story-player data-initial-paused={initialPaused ? 'true' : 'false'}>
      <div class="story-ambient" aria-hidden="true">
        <img src={ambientSrc || undefined} alt="" loading="eager" decoding="async" data-story-ambient />
      </div>
      <div class="stage-top">
        <div class="rail-avatar-menu">
          <button class="rail-avatar-menu__button" type="button" aria-label={ui.menu}>
            <img src="/brand-avatar-small-20260629.webp" alt="" width="34" height="34" />
          </button>
          <div class="rail-avatar-menu__panel">
            <a href={isRu ? '/ru/' : '/'}>Alex Getman</a>
            <a class="notranslate" href={isRu ? '/' : '/ru/'}>{ui.language}</a>
            <a href="https://t.me/alexgetmancom" target="_blank" rel="noopener noreferrer">{ui.telegram}</a>
          </div>
        </div>
        <div class="feed-mode-pills" role="group" aria-label={ui.feedMode}>
          <button class="feed-pill is-active" type="button" data-feed-mode="latest">{ui.feedLatest}</button>
          <button class="feed-pill" type="button" data-feed-mode="deep">{ui.feedDeep}</button>
          <button class="feed-pill" type="button" data-feed-mode="watched">{ui.feedWatched}</button>
        </div>
      </div>
      <div class="story-player__main">
        <div class="story-rail-container">
          <StoryRail posts={storyPosts} ui={ui} />
        </div>
        <div class="story-stage">
          <StoryVisual activePost={activePost} posts={storyPosts} ui={ui} />
          <StoryContext activePost={activePost} paragraphs={paragraphsFor(activePost)} ui={ui} />
        </div>
      </div>

      <script type="application/json" data-story-payload set:html={safeJsonForScript({
        ui,
        posts: storyPosts.map((post) => ({
          id: post.id,
          url: post.url,
          title: post.title,
          body: paragraphsFor(post),
          fullBody: fullTextFor(post),
          excerpt: post.excerpt,
          date: post.date,
          relativeDate: post.relativeDate,
          image: publicSrc(post.image),
          fallbackImage: publicSrc(post.fallbackImage),
          mediaType: post.mediaType || null,
          gallery: (post.gallery || []).map((media) => ({
            type: media.type,
            path: publicSrc(media.path),
            poster: publicSrc(media.poster),
          })),
          audioUrl: post.audioUrl || null,
          spotifyUrl: post.spotifyUrl || null,
          imageSrcSet: post.imageSrcSet || '',
          views: metricValue(post.views),
          category: post.category,
          feedModes: feedModesFor(post),
          readMore: ui.readMore,
          collapse: ui.collapse,
        })),
        initialPaused,
        giscus: {
          repo: 'alexgetmancom/alexgetman.com',
          repoId: 'R_kgDOSJwPnQ',
          category: 'Announcements',
          categoryId: 'DIC_kwDOSJwPnc4C-S2f',
          lang: isRu ? 'ru' : 'en',
        },
      })}></script>
      <noscript>
        <article class="story-seo-content">
          <h1>{activePost.title}</h1>
          {fullTextFor(activePost).map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      </noscript>
    </section>
  ) : (
    <p class="empty">{labels.empty}</p>
  )}
</main>

<script>
  import '../scripts/story-player-utils.ts';
  import '../scripts/home-news-player.ts';
</script>
