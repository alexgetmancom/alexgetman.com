---
import { storyUi } from "../features/story-player/i18n";
import { toPlayerPosts } from "../features/story-player/payload";
/* =============================================================================
 * ASTRO-ОБЁРТКА ПЛЕЕРА (SEO-слой). Сам плеер — features/story-player/.
 * -----------------------------------------------------------------------------
 * Зона ответственности ЭТОГО файла (и только его):
 *   1. Порядок постов: выбранный пост (страница статьи) встаёт первым.
 *   2. SEO: noscript-фолбэк для клиентов без JS — заголовок (<p>, единственный
 *      <h1> страницы рендерит гидрируемый StoryContext.svelte), медиа
 *      активного поста и полный текст.
 *   3. Производительность: <link rel="preload"> первой картинки/постера.
 *   4. Монтирование Svelte-острова <StoryPlayer client:load> (SSR-first).
 *
 * Интерактив, состояние, стили плеера — НЕ здесь: см.
 * features/story-player/README.md. Разметку плеера тут не добавлять.
 * ========================================================================== */
import StoryPlayer from "../features/story-player/StoryPlayer.svelte";
import "../styles/home-news-page.css";
import type { HomeLabels, HomePost } from "./home-news/types";

interface Props {
  posts: HomePost[];
  labels: HomeLabels;
  locale: "en" | "ru";
  initialPostId?: number | string;
  initialPaused?: boolean;
}

const { posts, labels, locale, initialPostId, initialPaused = false } = Astro.props;

const selectedPost = initialPostId ? posts.find((post) => String(post.id) === String(initialPostId)) : null;
const storyPosts = selectedPost ? [selectedPost, ...posts.filter((post) => String(post.id) !== String(selectedPost.id))] : posts;
const playerPosts = toPlayerPosts(storyPosts);
const activePost = playerPosts[0] || null;
const ui = storyUi(locale);
---

<main class="home-page">
  {activePost ? (
    <>
      {activePost.mediaType !== 'video' && activePost.image && (
        <link rel="preload" as="image" href={activePost.image} imagesrcset={activePost.imageSrcSet || undefined} imagesizes="(max-width: 760px) min(100vw - 2rem, 390px), 320px" fetchpriority="high" />
      )}
      {activePost.mediaType === 'video' && (activePost.posterSrc || activePost.fallbackImage) && (
        <link rel="preload" as="image" href={activePost.posterSrc || activePost.fallbackImage} fetchpriority="high" />
      )}
      <StoryPlayer client:load posts={playerPosts} ui={ui} locale={locale} initialPaused={initialPaused} />
      <noscript>
        <article class="story-seo-content">
          <p class="story-seo-title">{activePost.title}</p>
          {activePost.mediaType === 'video' && activePost.image ? (
            <video src={activePost.image} poster={activePost.posterSrc || activePost.fallbackImage || undefined} controls muted playsinline></video>
          ) : activePost.image ? (
            <img src={activePost.image} alt={activePost.title} />
          ) : null}
          {activePost.fullBody.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </article>
      </noscript>
    </>
  ) : (
    <p class="empty">{labels.empty}</p>
  )}
</main>

<script>
  import '../scripts/site-interactions.ts';
</script>
