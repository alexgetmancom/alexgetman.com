---
import Layout from '../../layouts/Layout.astro';
import HomeNewsPage from '../../components/HomeNewsPage.astro';
import projects from '../../data/projects.json';
import { loadFeedItems } from '../../utils/feed';
import { sortedHomePosts, topicStatsFor } from '../../utils/home-posts';

const feedItems = loadFeedItems();

const russianPosts = sortedHomePosts(feedItems, 'ru');

const leadPost = russianPosts[0] || null;
const latestRussianPosts = russianPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...russianPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => (b.views - a.views) || (new Date(b.date).getTime() - new Date(a.date).getTime()))
  .slice(0, 5);
const topicStats = topicStatsFor(russianPosts);

const title = "Алексей Гетманец | новости ИИ и developer tools";
const description = "Новости ИИ, developer tools, автоматизация и изменения продуктов от Алексея Гетманца.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      "name": "Алексей Гетманец",
      "alternateName": "Alex Getman",
      "url": "https://alexgetman.com/ru/",
      "image": "https://alexgetman.com/avatar.png",
      "sameAs": [
        "https://t.me/alexgetmancom",
        "https://www.threads.net/@alexgetmanru",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      "url": "https://alexgetman.com/ru/",
      "name": "Алексей Гетманец",
      "description": description,
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://alexgetman.com/#person" }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/ru/#home",
      "url": "https://alexgetman.com/ru/",
      "name": title,
      "description": description,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://alexgetman.com/#website" }
    }
  ]
});

const labels = {
  archive: "Архив",
  search: "Поиск",
  languageSwitch: "EN",
  empty: "Русские посты появятся здесь после публикации.",
  latestPosts: "Последние русские посты",
  latestUpdates: "Последние обновления",
  trending: "Популярное",
  topics: "Темы",
  projects: "Проекты",
  all: "Все",
  sidebarLabel: "Боковые разделы главной страницы",
  mskSuffix: "МСК"
};
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/ru/"
  lang="ru"
  siteName="Алексей Гетманец"
  rssHref="/ru/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={russianPosts}
    latestPosts={latestRussianPosts}
    trendingPosts={trendingPosts}
    topicStats={topicStats}
    projects={projects}
    labels={labels}
    locale="ru"
    categoryBasePath="/ru/category/"
  />
</Layout>
