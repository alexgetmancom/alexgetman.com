---
import HomeNewsPage from "../../components/HomeNewsPage.astro";
import Layout from "../../layouts/Layout.astro";
import { loadFeedItems } from "../../server/public-site";
import { sortedHomePosts } from "../../utils/home-posts";

export const prerender = false;

const feedItems = loadFeedItems();

const russianPosts = sortedHomePosts(feedItems, "ru");

const title = "Алекс Гетман — новости ИИ, моделей и AI-продуктов";
const description =
  "Свежие новости ИИ: новые модели, продукты и обновления OpenAI, ChatGPT Codex, Claude, Gemini и других. Релизы, тесты, цены, лимиты и комментарии.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      name: "Алекс Гетман",
      alternateName: "Alex Getman",
      url: "https://alexgetman.com/ru/",
      image: "https://alexgetman.com/avatar.png",
      sameAs: [
        "https://t.me/alexgetmancom",
        "https://www.threads.net/@alexgetmanru",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      url: "https://alexgetman.com/ru/",
      name: "Алекс Гетман",
      description: description,
      inLanguage: "ru-RU",
      publisher: { "@id": "https://alexgetman.com/#person" },
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/ru/#home",
      url: "https://alexgetman.com/ru/",
      name: title,
      description: description,
      inLanguage: "ru-RU",
      isPartOf: { "@id": "https://alexgetman.com/#website" },
    },
  ],
});

const labels = {
  empty: "Русские посты появятся здесь после публикации.",
};
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/ru/"
  lang="ru"
  siteName="Алекс Гетман"
  rssHref="/ru/feed.xml"
  socialImage="/brand-social-wide-20260720.jpg"
  socialImageWidth={1200}
  socialImageHeight={630}
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={russianPosts}
    labels={labels}
    locale="ru"
  />
</Layout>
