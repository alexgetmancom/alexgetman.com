---
import Layout from "../../../../layouts/Layout.astro";
import { loadFeedItems } from "../../../../server/public-site";
import { getFirstSentence } from "../../../../utils/text";

export const prerender = false;
const { kind, slug } = Astro.params;
const allowedKinds = new Set(["company", "model", "person", "product", "topic"]);
if (!kind || !slug || !allowedKinds.has(kind)) return new Response("Not found\n", { status: 404 });
const posts = loadFeedItems().filter((post) => post.has_ru && post.entities.some((entity) => entity.kind === kind && entity.slug === slug));
const entity = posts.flatMap((post) => post.entities).find((item) => item.kind === kind && item.slug === slug);
if (!entity) return new Response("Not found\n", { status: 404 });
const title = entity.title_ru;
const url = `https://alexgetman.com/ru/entities/${kind}/${slug}/`;
const enUrl = `https://alexgetman.com/entities/${kind}/${slug}/`;
---

<Layout title={`${title} | Алекс Гетман`} description={`Новости и контекст про ${title}.`} canonicalUrl={url} lang="ru" siteName="Алекс Гетман" alternateLinks={[{ hreflang: "ru", href: url }, { hreflang: "en", href: enUrl }, { hreflang: "x-default", href: enUrl }]}>
  <main class="entity-page"><h1>{title}</h1><p>Новости и контекст.</p><ol>{posts.map((post) => <li><a href={`/ru/${post.post_id}/${post.slug_ru}/`}>{getFirstSentence(post.text) || `Пост ${post.post_id}`}</a></li>)}</ol></main>
</Layout>
<style>.entity-page { max-width: 720px; margin: 0 auto; padding: 5rem 1.5rem; } h1 { margin-bottom: .5rem; } ol { padding-left: 1.2rem; line-height: 1.6; } a { color: inherit; }</style>
