---
import LegacyRedirect from "../../../../components/LegacyRedirect.astro";
import { loadFeedItems } from "../../../../server/public-site";

export const prerender = false;

const { postId } = Astro.params;
const item = loadFeedItems().find((entry) => String(entry.post_id) === String(postId) && entry.has_ru);
const target = item?.slug_ru ? `/ru/${item.post_id}/${item.slug_ru}/` : "/ru/";
---

<LegacyRedirect target={target} title="Адрес поста изменился" message="Эта страница переехала в canonical-пост." lang="ru" />
