---
import Layout from "../../layouts/Layout.astro";
import { loadFeedItems } from "../../server/public-site";
import { getFirstSentence } from "../../utils/text";

export const prerender = false;
const { hub } = Astro.params;
const hubs = {
  codex: {
    kind: "product",
    slug: "codex",
    title: "Codex",
    intro: "Агентская среда OpenAI для работы с кодом. Здесь собраны релизы, доступ, лимиты, сценарии и реальные изменения.",
  },
  claude: {
    kind: "product",
    slug: "claude",
    title: "Claude",
    intro: "Линейка моделей Anthropic. Здесь собраны релизы, доступ, лимиты, Claude Code, Cowork и важные изменения.",
  },
  kimi: {
    kind: "model",
    slug: "kimi-k3",
    title: "Kimi",
    intro: "Kimi K3 и линейка Moonshot AI: релизы, цены API, бенчмарки, доступ и реальная реакция рынка.",
  },
} as const;
const definition = hub && hub in hubs ? hubs[hub as keyof typeof hubs] : null;
if (!definition) return new Response("Not found\n", { status: 404 });
const posts = loadFeedItems().filter(
  (post) => post.has_ru && post.entities.some((entity) => entity.kind === definition.kind && entity.slug === definition.slug),
);
if (posts.length === 0) return new Response("Not found\n", { status: 404 });
const title = definition.title;
const url = `https://alexgetman.com/ru/${hub}/`;
---
<Layout title={`${title} | Алекс Гетман`} description={`Новости и контекст про ${title}.`} canonicalUrl={url} lang="ru" siteName="Алекс Гетман" alternateLinks={[{ hreflang: "ru", href: url }, { hreflang: "en", href: `https://alexgetman.com/${hub}/` }, { hreflang: "x-default", href: `https://alexgetman.com/${hub}/` }]}>
  <main class="hub"><h1>{title}</h1><p>{definition.intro}</p><h2>Последние обновления</h2><ol>{posts.map((post) => <li><a href={`/ru/${post.post_id}/${post.slug_ru}/`}>{getFirstSentence(post.text) || `Пост ${post.post_id}`}</a></li>)}</ol></main>
</Layout>
<style>.hub { max-width: 720px; margin: 0 auto; padding: 5rem 1.5rem; } ol { padding-left: 1.2rem; line-height: 1.6; } a { color: inherit; }</style>
