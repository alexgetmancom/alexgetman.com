---
import HomeNewsPage from "../../../components/HomeNewsPage.astro";
import Layout from "../../../layouts/Layout.astro";
import { loadFeedItems } from "../../../server/public-site";
import { sortedHomePosts } from "../../../utils/home-posts";
import { postOgImagePath, postVisualMedia } from "../../../utils/media";
import { excerptAfterTitle, getFirstSentence } from "../../../utils/text";

export const prerender = false;

const { postId, slug } = Astro.params;
const feedItems = loadFeedItems();
const item = feedItems.find((entry) => String(entry.post_id) === String(postId) && entry.slug_ru === slug);
if (!item) {
  const canonicalItem = feedItems.find((entry) => String(entry.post_id) === String(postId) && entry.has_ru && entry.slug_ru);
  if (canonicalItem?.slug_ru) return Astro.redirect(`/ru/${canonicalItem.post_id}/${canonicalItem.slug_ru}/`, 301);
  return new Response("Not found\n", { status: 404 });
}
const russianPosts = sortedHomePosts(feedItems, "ru");
const selectedPost = russianPosts.find((post) => String(post.id) === String(postId));
const siteAuthor = "Алекс Гетман";
const postText = item.text || "";
const pageTitle = selectedPost?.title || getFirstSentence(postText) || `Публикация ${postId}`;
const postDescription =
  excerptAfterTitle(postText, pageTitle, 158) || "Новости ИИ, заметки об автоматизации и разработке от Алекса Гетмана на alexgetman.com.";
const localUrl = `https://alexgetman.com/ru/${postId}/${slug}/`;
const ogImage = postOgImagePath(item, "ru");
const visualMedia = postVisualMedia(item, "ru");
const primaryVideo = visualMedia?.type === "video" ? visualMedia : null;
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      headline: pageTitle,
      description: postDescription,
      url: localUrl,
      datePublished: item.date,
      dateModified: item.date,
      inLanguage: "ru-RU",
      author: {
        "@type": "Person",
        name: siteAuthor,
        url: "https://alexgetman.com/ru/",
      },
      publisher: {
        "@type": "Person",
        name: siteAuthor,
        url: "https://alexgetman.com/ru/",
      },
      mainEntityOfPage: localUrl,
      image: [`https://alexgetman.com${ogImage}`],
    },
    ...(primaryVideo
      ? [
          {
            "@type": "VideoObject",
            name: pageTitle,
            description: postDescription,
            thumbnailUrl: [`https://alexgetman.com/${primaryVideo.poster || ogImage.replace(/^\//, "")}`],
            uploadDate: item.date,
            contentUrl: `https://alexgetman.com/${primaryVideo.path}`,
            embedUrl: localUrl,
            mainEntityOfPage: localUrl,
            inLanguage: "ru-RU",
          },
        ]
      : []),
  ],
});

const labels = {
  empty: "Русские посты появятся здесь после публикации.",
};
---

<Layout
  title={`${pageTitle} | ${siteAuthor}`}
  description={postDescription}
  schema={schema}
  canonicalUrl={localUrl}
  lang="ru"
  siteName={siteAuthor}
  rssHref="/ru/feed.xml"
  socialImage={ogImage}
  socialImageWidth={1200}
  socialImageHeight={630}
  ogType="article"
  alternateLinks={[
    ...(item.has_en ? [{ hreflang: 'en', href: `https://alexgetman.com/${postId}/${item.slug_en}/` }] : []),
    { hreflang: 'ru', href: localUrl },
    ...(item.has_en ? [{ hreflang: 'x-default', href: `https://alexgetman.com/${postId}/${item.slug_en}/` }] : [])
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={russianPosts}
    labels={labels}
    locale="ru"
    initialPostId={postId}
  />
</Layout>
