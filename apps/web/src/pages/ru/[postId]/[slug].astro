---
import HomeNewsPage from "../../../components/HomeNewsPage.astro";
import projects from "../../../data/projects.json";
import Layout from "../../../layouts/Layout.astro";
import { loadFeedItems } from "../../../utils/feed";
import { getFirstSentence, postOgImagePath, truncateText } from "../../../utils/helpers";
import { sortedHomePosts, topicStatsFor } from "../../../utils/home-posts";

export const prerender = false;

const { postId, slug } = Astro.params;
const feedItems = loadFeedItems();
const item = feedItems.find((entry: any) => String(entry.post_id) === String(postId) && entry.slug_ru === slug) ?? {};
const russianPosts = sortedHomePosts(feedItems, "ru");
const selectedPost = russianPosts.find((post) => String(post.id) === String(postId));
const leadPost = russianPosts[0] || null;
const latestRussianPosts = russianPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...russianPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => b.views - a.views || new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 5);
const topicStats = topicStatsFor(russianPosts);

const siteAuthor = "Алексей Гетманец";
const postText = item.text || "";
const pageTitle = selectedPost?.title || getFirstSentence(postText) || `Публикация ${postId}`;
const postDescription =
  truncateText(postText.replace(/\s+/g, " "), 158) ||
  "Новости ИИ, заметки об автоматизации и разработке от Алексея Гетманца на alexgetman.com.";
const localUrl = `https://alexgetman.com/ru/${postId}/${slug}/`;
const ogImage = postOgImagePath(item, "ru");
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: postDescription,
  url: localUrl,
  datePublished: item.date,
  dateModified: item.date,
  inLanguage: "ru-RU",
  author: {
    "@type": "Person",
    name: siteAuthor,
    url: "https://alexgetman.com/ru/",
  },
  publisher: {
    "@type": "Person",
    name: siteAuthor,
    url: "https://alexgetman.com/ru/",
  },
  mainEntityOfPage: localUrl,
  image: [`https://alexgetman.com${ogImage}`],
});

const labels = {
  archive: "Архив",
  search: "Поиск",
  languageSwitch: "EN",
  empty: "Русские посты появятся здесь после публикации.",
  latestPosts: "Последние русские посты",
  latestUpdates: "Последние обновления",
  trending: "Популярное",
  topics: "Темы",
  projects: "Проекты",
  all: "Все",
  sidebarLabel: "Боковые разделы главной страницы",
  mskSuffix: "МСК",
};
---

<Layout
  title={`${pageTitle} | ${siteAuthor}`}
  description={postDescription}
  schema={schema}
  canonicalUrl={localUrl}
  lang="ru"
  siteName={siteAuthor}
  rssHref="/ru/feed.xml"
  socialImage={ogImage}
  socialImageWidth={1200}
  socialImageHeight={630}
  ogType="article"
  alternateLinks={[
    ...(item.has_en ? [{ hreflang: 'en', href: `https://alexgetman.com/${postId}/${item.slug_en}/` }] : []),
    { hreflang: 'ru', href: localUrl },
    ...(item.has_en ? [{ hreflang: 'x-default', href: `https://alexgetman.com/${postId}/${item.slug_en}/` }] : [])
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={russianPosts}
    latestPosts={latestRussianPosts}
    trendingPosts={trendingPosts}
    topicStats={topicStats}
    projects={projects}
    labels={labels}
    locale="ru"
    categoryBasePath="/ru/category/"
    initialPostId={postId}
    initialPaused
  />
</Layout>
