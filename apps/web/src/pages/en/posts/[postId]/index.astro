---
import LegacyRedirect from "../../../../components/LegacyRedirect.astro";
import { loadFeedItems } from "../../../../utils/feed";

export const prerender = false;

const { postId } = Astro.params;
const item = loadFeedItems().find((entry) => String(entry.post_id) === String(postId) && entry.has_en);
const target = item?.slug_en ? `/${item.post_id}/${item.slug_en}/` : "/";
---

<LegacyRedirect target={target} title="English post URL moved" />
