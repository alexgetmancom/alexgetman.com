---
import LegacyRedirect from "../../../../components/LegacyRedirect.astro";
import { loadFeedItems } from "../../../../utils/feed";

export async function getStaticPaths() {
  return loadFeedItems()
    .filter((item: any) => item.has_en && item.post_id && item.slug_en)
    .map((item: any) => ({ params: { postId: String(item.post_id) }, props: { item } }));
}

const { item } = Astro.props;
---

<LegacyRedirect target={`/${item.post_id}/${item.slug_en}/`} title="English post URL moved" />
