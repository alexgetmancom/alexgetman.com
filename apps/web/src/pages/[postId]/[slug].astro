---
import HomeNewsPage from "../../components/HomeNewsPage.astro";
import Layout from "../../layouts/Layout.astro";
import { loadFeedItems } from "../../server/public-site";
import { entityUrl } from "../../utils/entity-url";
import { sortedHomePosts } from "../../utils/home-posts";
import { postOgImagePath, postVisualMedia } from "../../utils/media";
import { excerptAfterTitle, getFirstSentence } from "../../utils/text";

export const prerender = false;

const { postId, slug } = Astro.params;
const feedItems = loadFeedItems();
const item = feedItems.find((entry) => String(entry.post_id) === String(postId) && entry.slug_en === slug);
if (!item) {
  const canonicalItem = feedItems.find((entry) => String(entry.post_id) === String(postId) && entry.has_en && entry.slug_en);
  if (canonicalItem?.slug_en) return Astro.redirect(`/${canonicalItem.post_id}/${canonicalItem.slug_en}/`, 301);
  return new Response("Not found\n", { status: 404 });
}
const englishPosts = sortedHomePosts(feedItems, "en");
const selectedPost = englishPosts.find((post) => String(post.id) === String(postId));
const siteAuthor = "Alex Getman";
const postText = item.text_en || item.text || "";
const pageTitle = selectedPost?.title || getFirstSentence(postText) || `Post ${postId}`;
const postDescription =
  excerptAfterTitle(postText, pageTitle, 158) || "AI news, automation notes and developer updates by Alex Getman on alexgetman.com.";
const localUrl = `https://alexgetman.com/${postId}/${slug}/`;
const ogImage = postOgImagePath(item, "en");
const visualMedia = postVisualMedia(item, "en");
const primaryVideo = visualMedia?.type === "video" ? visualMedia : null;
const sourceUrls = item.sources.map((source) => source.url);
const about = item.entities.map((entity) => ({
  "@type": "Thing",
  name: entity.title_en || entity.title_ru,
  url: `https://alexgetman.com${entityUrl(entity.kind, entity.slug)}`,
}));
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      headline: pageTitle,
      description: postDescription,
      url: localUrl,
      datePublished: item.date,
      dateModified: item.date,
      inLanguage: "en-US",
      author: {
        "@type": "Person",
        name: siteAuthor,
        url: "https://alexgetman.com/",
      },
      publisher: {
        "@type": "Person",
        name: siteAuthor,
        url: "https://alexgetman.com/",
      },
      mainEntityOfPage: localUrl,
      image: [`https://alexgetman.com${ogImage}`],
      ...(sourceUrls.length > 0 ? { isBasedOn: sourceUrls, citation: sourceUrls } : {}),
      ...(about.length > 0 ? { about } : {}),
    },
    ...(primaryVideo
      ? [
          {
            "@type": "VideoObject",
            name: pageTitle,
            description: postDescription,
            thumbnailUrl: [`https://alexgetman.com/${primaryVideo.poster || ogImage.replace(/^\//, "")}`],
            uploadDate: item.date,
            contentUrl: `https://alexgetman.com/${primaryVideo.path}`,
            embedUrl: localUrl,
            mainEntityOfPage: localUrl,
            inLanguage: "en-US",
          },
        ]
      : []),
  ],
});

const labels = {
  empty: "English posts will appear here after publication approval.",
};
---

<Layout
  title={`${pageTitle} | ${siteAuthor}`}
  description={postDescription}
  schema={schema}
  canonicalUrl={localUrl}
  lang="en"
  siteName={siteAuthor}
  rssHref="/feed.xml"
  socialImage={ogImage}
  socialImageWidth={1200}
  socialImageHeight={630}
  ogType="article"
  alternateLinks={[
    { hreflang: 'en', href: localUrl },
    ...(item.has_ru ? [{ hreflang: 'ru', href: `https://alexgetman.com/ru/${postId}/${item.slug_ru}/` }] : []),
    { hreflang: 'x-default', href: localUrl }
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={englishPosts}
    labels={labels}
    locale="en"
    initialPostId={postId}
  />
</Layout>
