---
import HomeNewsPage from "../../components/HomeNewsPage.astro";
import projects from "../../data/projects.json";
import Layout from "../../layouts/Layout.astro";
import { loadFeedItems } from "../../utils/feed";
import { getFirstSentence, postOgImagePath, truncateText } from "../../utils/helpers";
import { sortedHomePosts, topicStatsFor } from "../../utils/home-posts";

export const prerender = false;

const { postId, slug } = Astro.params;
const feedItems = loadFeedItems();
const item = feedItems.find((entry: any) => String(entry.post_id) === String(postId) && entry.slug_en === slug) ?? {};
const englishPosts = sortedHomePosts(feedItems, "en");
const selectedPost = englishPosts.find((post) => String(post.id) === String(postId));
const leadPost = englishPosts[0] || null;
const latestEnglishPosts = englishPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...englishPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => b.views - a.views || new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 5);
const topicStats = topicStatsFor(englishPosts);

const siteAuthor = "Alex Getman";
const postText = item.text_en || item.text || "";
const pageTitle = selectedPost?.title || getFirstSentence(postText) || `Post ${postId}`;
const postDescription =
  truncateText(postText.replace(/\s+/g, " "), 158) || "AI news, automation notes and developer updates by Alex Getman on alexgetman.com.";
const localUrl = `https://alexgetman.com/${postId}/${slug}/`;
const ogImage = postOgImagePath(item, "en");
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: postDescription,
  url: localUrl,
  datePublished: item.date,
  dateModified: item.date,
  inLanguage: "en-US",
  author: {
    "@type": "Person",
    name: siteAuthor,
    url: "https://alexgetman.com/",
  },
  publisher: {
    "@type": "Person",
    name: siteAuthor,
    url: "https://alexgetman.com/",
  },
  mainEntityOfPage: localUrl,
  image: [`https://alexgetman.com${ogImage}`],
});

const labels = {
  archive: "Archive",
  search: "Search",
  languageSwitch: "RU",
  empty: "English posts will appear here after publication approval.",
  latestPosts: "Latest English posts",
  latestUpdates: "Latest updates",
  trending: "Trending",
  topics: "Topics",
  projects: "Projects",
  all: "All",
  sidebarLabel: "Homepage side sections",
  mskSuffix: "MSK",
};
---

<Layout
  title={`${pageTitle} | ${siteAuthor}`}
  description={postDescription}
  schema={schema}
  canonicalUrl={localUrl}
  lang="en"
  siteName={siteAuthor}
  rssHref="/feed.xml"
  socialImage={ogImage}
  socialImageWidth={1200}
  socialImageHeight={630}
  ogType="article"
  alternateLinks={[
    { hreflang: 'en', href: localUrl },
    ...(item.has_ru ? [{ hreflang: 'ru', href: `https://alexgetman.com/ru/${postId}/${item.slug_ru}/` }] : []),
    { hreflang: 'x-default', href: localUrl }
  ]}
  immersiveHome
>
  <HomeNewsPage
    posts={englishPosts}
    latestPosts={latestEnglishPosts}
    trendingPosts={trendingPosts}
    topicStats={topicStats}
    projects={projects}
    labels={labels}
    locale="en"
    categoryBasePath="/category/"
    initialPostId={postId}
    initialPaused
  />
</Layout>
