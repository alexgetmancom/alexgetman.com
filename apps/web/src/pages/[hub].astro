---
import Layout from "../layouts/Layout.astro";
import { loadFeedItems } from "../server/public-site";
import { getFirstSentence } from "../utils/text";

export const prerender = false;
const { hub } = Astro.params;
if (hub !== "codex" && hub !== "claude") return new Response("Not found\n", { status: 404 });
const posts = loadFeedItems().filter(
  (post) => post.has_en && post.entities.some((entity) => entity.kind === "product" && entity.slug === hub),
);
if (posts.length === 0) return new Response("Not found\n", { status: 404 });
const title = hub === "codex" ? "Codex" : "Claude";
const url = `https://alexgetman.com/${hub}/`;
---
<Layout title={`${title} | Alex Getman`} description={`Latest news and context about ${title}.`} canonicalUrl={url} lang="en" siteName="Alex Getman" alternateLinks={[{ hreflang: "en", href: url }, { hreflang: "ru", href: `https://alexgetman.com/ru/${hub}/` }, { hreflang: "x-default", href: url }]}>
  <main class="hub"><h1>{title}</h1><p>Latest news and context.</p><ol>{posts.map((post) => <li><a href={`/${post.post_id}/${post.slug_en}/`}>{getFirstSentence(post.text_en) || `Post ${post.post_id}`}</a></li>)}</ol></main>
</Layout>
<style>.hub { max-width: 720px; margin: 0 auto; padding: 5rem 1.5rem; } ol { padding-left: 1.2rem; line-height: 1.6; } a { color: inherit; }</style>
