---
import LegacyRedirect from "../../../components/LegacyRedirect.astro";
import { loadFeedItems } from "../../../utils/feed";

export const prerender = false;

const { postId } = Astro.params;
const item = loadFeedItems().find((entry: any) => String(entry.post_id) === String(postId)) ?? {};
const target = item?.has_en && item?.slug_en ? `/${item.post_id}/${item.slug_en}/` : `/ru/${item.post_id}/${item.slug_ru}/`;
---

<LegacyRedirect target={target} title="Post URL moved" />
