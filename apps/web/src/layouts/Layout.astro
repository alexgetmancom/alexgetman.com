---
import { removeLeadingEmoji } from "../utils/helpers";
import "../styles/layout.css";

interface Props {
  title?: string;
  description?: string;
  schema?: string;
  canonicalUrl?: string;
  lang?: string;
  siteName?: string;
  rssHref?: string;
  alternateLinks?: Array<{ hreflang: string; href: string }>;
  robots?: string;
  socialImage?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
  ogType?: string;
  immersiveHome?: boolean;
}

const {
  title = "Алексей Гетманец | Сливы и новости ИИ",
  description = "Алексей Гетманец пишет об AI, разработке, автоматизации, self-hosted системах и инструментах для разработчиков.",
  schema,
  canonicalUrl = Astro.url.href,
  lang = "ru",
  siteName = "Алексей Гетманец",
  rssHref = "/feed.xml",
  alternateLinks = [],
  robots = "index, follow",
  socialImage: socialImageProp,
  socialImageWidth = 500,
  socialImageHeight = 500,
  ogType = "website",
  immersiveHome = false,
} = Astro.props;

const cleanDescription = removeLeadingEmoji(description);
const publicBaseUrl = "https://alexgetman.com";
const brandAssetVersion = "20260629-new-avatar";
const socialImage = socialImageProp
  ? socialImageProp.startsWith("http")
    ? socialImageProp
    : `${publicBaseUrl}${socialImageProp.startsWith("/") ? socialImageProp : `/${socialImageProp}`}`
  : `${publicBaseUrl}/brand-social-20260629.jpg`;
const twitterCard = socialImageWidth >= 1000 ? "summary_large_image" : "summary";
const safeSchema = schema?.replace(/</g, "\\u003c").replace(/>/g, "\\u003e").replace(/&/g, "\\u0026");
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={cleanDescription} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#080B10" />
    <link rel="icon" type="image/png" href="/brand-favicon-20260629.png" />
    <link rel="apple-touch-icon" href="/brand-favicon-20260629.png" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${brandAssetVersion}`} />
    <link rel="alternate icon" type="image/x-icon" href={`/favicon.ico?v=${brandAssetVersion}`} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={title} href={rssHref} />
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
    <link rel="api-catalog" type="application/linkset+json" href="/.well-known/api-catalog" />
    <link rel="agent-skills" type="application/json" href="/.well-known/agent-skills/index.json" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title.split(" | ")[0]} />
    <meta property="og:description" content={cleanDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content={String(socialImageWidth)} />
    <meta property="og:image:height" content={String(socialImageHeight)} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title.split(" | ")[0]} />
    <meta name="twitter:description" content={cleanDescription} />
    <meta name="twitter:image" content={socialImage} />
    {safeSchema && <script type="application/ld+json" set:html={safeSchema}></script>}
    <script is:inline>
      (() => {
        const registerWebMCP = async () => {
          if (!navigator.modelContext) return;
          try {
            const provideContext = navigator.modelContext.provideContext || navigator.modelContext.registerTool;
            if (typeof provideContext !== "function") return;
            const tool = {
              name: "read_feed",
              description: "Get the latest AI news, automation notes and developer updates from alexgetman.com.",
              inputSchema: { type: "object", properties: { limit: { type: "number", description: "Number of posts to return (default 5, max 12)" } } },
              execute: async (args) => {
                try {
                  const response = await fetch("/feed.json");
                  const data = await response.json();
                  return { result: (data.items || data).slice(0, args.limit || 5) };
                } catch (error) {
                  return { error: error instanceof Error ? error.message : String(error) };
                }
              },
            };
            if (navigator.modelContext.provideContext) await navigator.modelContext.provideContext({ tools: [tool] });
            else await navigator.modelContext.registerTool(tool, tool.execute);
          } catch {}
        };
        registerWebMCP();
      })();
    </script>
  </head>
  <body class={immersiveHome ? "immersive-home" : undefined}>
    <a class="skip-link" href="#main-content">{lang === "ru" ? "К содержанию" : "Skip to content"}</a>
    <main class="container" id="main-content" tabindex="-1"><slot /></main>
    <script>import "../scripts/site-interactions.ts";</script>
  </body>
</html>
