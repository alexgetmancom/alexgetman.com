#!/usr/bin/env sh
set -eu

OUT="${1:-/tmp/alexgetman-posting-fixture.db}"
rm -f "$OUT"
PIPELINE_DB="$OUT" DATA_DIR="$(dirname "$OUT")" python3 - <<'PY'
import json
import os
import sqlite3
from datetime import datetime, timezone
from pathlib import Path
import sys

sys.path.insert(0, str(Path.cwd() / "posting"))
import pipeline_metrics
from posting_core.control.service import sync_control_plane
from posting_core.db import ensure_pipeline_schema

db_path = Path(os.environ["PIPELINE_DB"])
conn = sqlite3.connect(str(db_path))
conn.row_factory = sqlite3.Row
ensure_pipeline_schema(conn)
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat()
post_key = "telegram:alexgetmancom:999"
conn.execute("""
INSERT INTO posts(post_key, source, channel, chat_id, message_id, date_utc, date_msk, text, text_en, media_json, media_count, media_types_json, site_ru_path, site_en_path, telegram_url, status, created_at, updated_at, raw_json)
VALUES (?, 'telegram', 'alexgetmancom', '-100', 999, ?, '2026-06-21 00:00', 'fixture ru', 'fixture en', ?, 1, ?, '/ru/posts/999/', '/en/posts/999/', 'https://t.me/alexgetmancom/999', 'active', ?, ?, '{}')
""", (post_key, now, json.dumps([{"type":"photo","file_id":"fixture"}]), json.dumps(["photo"]), now, now))
for target in ["telegram", "site_ru", "site_en", "threads_ru", "linkedin"]:
    conn.execute("INSERT INTO post_targets(post_key,target,status,url,updated_at) VALUES(?,?,?,?,?)", (post_key, target, "published", f"https://example.com/{target}", now))
conn.commit()
sync_control_plane(conn)
conn.close()
print(db_path)
PY
