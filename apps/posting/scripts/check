#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

if [ -x .venv/bin/python ]; then
  PYTHON=.venv/bin/python
else
  PYTHON="${PYTHON:-python3}"
fi

"$PYTHON" -m compileall -q posting posting_core site_feed tests scripts/postingctl
"$PYTHON" -m ruff check .
"$PYTHON" -m ruff format --check tests
"$PYTHON" -m pytest
./scripts/check-secrets
