#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

if grep -RInE '(AA[A-Za-z0-9_-]{20,}|xox[baprs]-|sk-[A-Za-z0-9_-]{20,}|access_token=|BEGIN (RSA |OPENSSH |EC )?PRIVATE KEY|FACEBOOK_PAGE_ACCESS_TOKEN=.+|LINKEDIN_ACCESS_TOKEN=.+|THREADS_ACCESS_TOKEN=.+|TELEGRAM_BOT_TOKEN=.+|CONTROLLER_BOT_TOKEN=.+)' \
  --exclude-dir=.git \
  --exclude-dir=.venv \
  --exclude-dir=venv \
  --exclude-dir='*.egg-info' \
  --exclude-dir=build \
  --exclude-dir=dist \
  --exclude='*.example' \
  --exclude='check-secrets' \
  .; then
  echo "Potential secret found" >&2
  exit 1
fi

echo "OK: no obvious secrets"
