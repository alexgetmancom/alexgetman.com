#!/usr/bin/env sh
set -eu

HOST="${HOST:-tw-nl}"
BACKUP_PATH="${1:-}"
if [ -z "$BACKUP_PATH" ]; then
  echo "usage: scripts/restore-db /opt/alexgetman-posting/data/backups/pipeline-YYYYmmddTHHMMSSZ.db" >&2
  exit 2
fi

ssh "$HOST" "test -f '$BACKUP_PATH'"
ssh "$HOST" "cd /opt/alexgetman-posting && docker compose stop posting-app site-feed"
ssh "$HOST" "cp '$BACKUP_PATH' /opt/alexgetman-posting/data/pipeline.db && chmod 664 /opt/alexgetman-posting/data/pipeline.db"
ssh "$HOST" "cd /opt/alexgetman-posting && docker compose up -d posting-app site-feed"
./scripts/smoke
