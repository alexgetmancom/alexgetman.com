#!/usr/bin/env python3
import argparse
import os
import re
import subprocess
import sys
from pathlib import Path

# Map of aliases to actual variable names in secrets.env
ALIAS_MAP = {
    "facebook": "FACEBOOK_PAGE_ACCESS_TOKEN",
    "facebook_ru": "FACEBOOK_RU_PAGE_ACCESS_TOKEN",
    "threads": "THREADS_ACCESS_TOKEN",
    "threads_ru": "THREADS_ACCESS_TOKEN",
    "threads_en": "THREADS_EN_ACCESS_TOKEN",
    "linkedin": "LINKEDIN_ACCESS_TOKEN",
    "x": "X_ACCESS_TOKEN",
    "x_token": "X_ACCESS_TOKEN",
    "x_secret": "X_ACCESS_TOKEN_SECRET",
    "deepseek": "DEEPSEEK_API_KEY",
    "telegram": "CONTROLLER_BOT_TOKEN",
    "telegram_token": "CONTROLLER_BOT_TOKEN",
}


def main():
    parser = argparse.ArgumentParser(description="Утилита для обновления секретов и перезапуска контейнеров")
    parser.add_argument("key", help="Имя переменной (или алиас: facebook, facebook_ru, threads, linkedin, x, deepseek)")
    parser.add_argument("value", help="Новое значение секрета")
    args = parser.parse_args()

    # Resolve target key name
    target_key = ALIAS_MAP.get(args.key.lower(), args.key)

    # Find secrets.env location
    project_root = Path(__file__).resolve().parent.parent
    secrets_path = project_root / "secrets.env"
    
    # Fallback to server absolute path if not exists locally
    if not secrets_path.exists() and Path("/opt/alexgetman-posting/secrets.env").exists():
        secrets_path = Path("/opt/alexgetman-posting/secrets.env")
        project_root = Path("/opt/alexgetman-posting")

    if not secrets_path.exists():
        print(f"Error: secrets.env file not found at {secrets_path}")
        sys.exit(1)

    print(f"Reading secrets from {secrets_path}...")
    content = secrets_path.read_text(encoding="utf-8")

    # Check if variable already exists
    pattern = rf"^{re.escape(target_key)}=.*$"
    replacement = f"{target_key}={args.value}"

    if re.search(pattern, content, re.MULTILINE):
        # Replace existing
        new_content = re.sub(pattern, replacement, content, flags=re.MULTILINE)
        print(f"Updating existing key: {target_key}")
    else:
        # Append new
        if content and not content.endswith("\n"):
            content += "\n"
        new_content = content + replacement + "\n"
        print(f"Appending new key: {target_key}")

    # Write changes back
    secrets_path.write_text(new_content, encoding="utf-8")
    secrets_path.chmod(0o600)
    print("secrets.env updated successfully.")

    # Recreate docker containers to apply changes
    compose_file = project_root / "compose.yaml"
    if compose_file.exists():
        print("Recreating posting-stack containers to apply new secrets...")
        # Container that depends on secrets.env.
        cmd = [
            "docker", "compose", "up", "-d",
            "posting-app"
        ]
        
        res = subprocess.run(cmd, cwd=str(project_root), capture_output=True, text=True)
        if res.returncode == 0:
            print(res.stdout.strip())
            print("Containers recreated successfully. New secrets applied.")
        else:
            print(f"Error recreating containers: {res.stderr.strip()}")
            sys.exit(1)
    else:
        print("Warning: compose.yaml not found, skipping container recreation.")


if __name__ == "__main__":
    main()
