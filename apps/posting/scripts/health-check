#!/usr/bin/env python3
import json
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path

# ANSI color codes
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
BOLD = "\033[1m"
RESET = "\033[0m"


def print_ok(msg):
    print(f"  [{GREEN}OK{RESET}] {msg}")


def print_fail(msg):
    print(f"  [{RED}FAIL{RESET}] {msg}")


def print_warn(msg):
    print(f"  [{YELLOW}WARN{RESET}] {msg}")


def check_docker_containers():
    print(f"\n{BOLD}1. Проверка Docker-контейнеров...{RESET}")
    required_containers = [
        "alexgetman-telegram-bot-api",
        "alexgetman-posting-app",
        "alexgetman-site-feed"
    ]

    try:
        res = subprocess.run(["docker", "ps", "--format", "{{.Names}} ({{.Status}})"], capture_output=True, text=True)
        if res.returncode != 0:
            print_fail(f"Не удалось выполнить docker ps: {res.stderr.strip()}")
            return False

        running_containers = res.stdout.strip().split("\n")
        running_names = [c.split()[0] for c in running_containers if c]

        all_ok = True
        for name in required_containers:
            found = False
            for rc in running_containers:
                if rc.startswith(name):
                    print_ok(f"Контейнер запущен: {rc}")
                    found = True
                    break
            if not found:
                print_fail(f"Контейнер НЕ запущен или отсутствует: {name}")
                all_ok = False
        return all_ok
    except Exception as exc:
        print_fail(f"Ошибка проверки докера: {exc}")
        return False


def check_http_endpoint(name, url, expected_code=200, contains_text=None, timeout=5):
    try:
        req = urllib.request.Request(
            url,
            headers={"User-Agent": "Mozilla/5.0 (Posting-Stack Health Check)"}
        )
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            code = resp.getcode()
            body = resp.read().decode("utf-8")
            
            if code != expected_code:
                print_fail(f"{name} ({url}) вернул код {code} вместо {expected_code}")
                return False
                
            if contains_text and contains_text not in body:
                print_fail(f"{name} ({url}) вернул ответ, но в нем отсутствует ключевой текст '{contains_text}'")
                return False
                
            print_ok(f"{name} ({url}) доступен [HTTP {code}]")
            return True
    except urllib.error.HTTPError as exc:
        code = exc.code
        try:
            body = exc.read().decode("utf-8")
        except Exception:
            body = ""
        if code == expected_code:
            if contains_text and contains_text not in body:
                print_fail(f"{name} ({url}) вернул код {code}, но в нем отсутствует ключевой текст '{contains_text}'")
                return False
            print_ok(f"{name} ({url}) доступен [HTTP {code} (ожидаемо)]")
            return True
        else:
            print_fail(f"{name} ({url}) вернул код {code} вместо {expected_code}: {exc}")
            return False
    except Exception as exc:
        print_fail(f"Ошибка подключения к {name} ({url}): {exc}")
        return False


def check_endpoints():
    print(f"\n{BOLD}2. Проверка сетевых эндпоинтов...{RESET}")
    success = True
    
    # Local Telegram Bot API (needs to be checked from host/server context)
    success &= check_http_endpoint(
        "Local Telegram Bot API",
        "http://127.0.0.1:8081",
        expected_code=404  # root usually returns 404/not found, which is normal behavior
    )

    # Site main
    success &= check_http_endpoint(
        "alexgetman.com",
        "https://alexgetman.com",
        contains_text="alexgetmancom"
    )

    # Owner dashboards are intentionally protected by Nginx Basic Auth.
    success &= check_http_endpoint(
        "Pipeline Status Page",
        "https://alexgetman.com/pipeline-status",
        expected_code=401
    )
    success &= check_http_endpoint(
        "Pipeline JSON API",
        "https://alexgetman.com/api/pipeline-status",
        expected_code=401
    )
    
    return success


def analyze_container_logs(container_name, lines=100):
    print(f"\n{BOLD}3. Анализ логов контейнера {container_name}...{RESET}")
    try:
        res = subprocess.run(["docker", "logs", "--tail", str(lines), container_name], capture_output=True, text=True)
        if res.returncode != 0:
            print_warn(f"Не удалось получить логи контейнера {container_name}")
            return

        logs = res.stdout.strip().split("\n")
        error_keywords = ["error", "exception", "oauth", "bad request", "fail", "invalidated"]
        
        errors_found = []
        for i, line in enumerate(logs):
            lower_line = line.lower()
            if any(keyword in lower_line for keyword in error_keywords):
                # Exclude debug/info info logs that contain these words naturally (if any)
                if "info" in lower_line and "error" not in lower_line:
                    continue
                errors_found.append((i + 1, line))

        if not errors_found:
            print_ok("Подозрительных ошибок в последних логах не обнаружено.")
        else:
            print_warn(f"Обнаружено {len(errors_found)} подозрительных записей об ошибках:")
            # Display last 5 errors found
            for idx, err in errors_found[-5:]:
                print(f"    Line {idx}: {err}")
    except Exception as exc:
        print_warn(f"Ошибка при анализе логов: {exc}")


def main():
    print(f"{BOLD}=== ДИАГНОСТИКА ПОСТИНГ-СТЕКА ALEXGETMANCOM ==={RESET}")
    
    docker_ok = check_docker_containers()
    endpoints_ok = check_endpoints()
    
    # Analyze logs for critical services
    analyze_container_logs("alexgetman-posting-app")
    analyze_container_logs("alexgetman-site-feed")
    
    print(f"\n{BOLD}=== ИТОГ ДИАГНОСТИКИ ==={RESET}")
    if docker_ok and endpoints_ok:
        print(f"{GREEN}{BOLD}Все системы работают штатно. Ошибок подключения нет.{RESET}")
        sys.exit(0)
    else:
        print(f"{RED}{BOLD}Внимание! Обнаружены проблемы в работе систем. См. лог выше.{RESET}")
        sys.exit(1)


if __name__ == "__main__":
    main()
