#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from posting_core.db import connect
from posting_core.db_migrations import apply_migrations, migration_status, verify_schema
from posting_core.metrics.maintenance import (
    apply_backfill_plan,
    audit_alerts,
    backup_database,
    build_backfill_plan,
    maintenance_lock,
    split_targets,
)
from posting_core.ops_lookup import resolve_publication_ref
from posting_core.paths import get_paths
from posting_core.repair import RepairService, parse_media
from posting_core.social_urls import target_public_url
from posting_core.targets import ALL_TARGET_IDS
from posting_core.verify import verify_target_record


def _age_seconds(value):
    if not value:
        return None
    try:
        dt = datetime.fromisoformat(str(value).replace("Z", "+00:00")).astimezone(timezone.utc)
    except Exception:
        return None
    return int((datetime.now(timezone.utc) - dt).total_seconds())


def collect_post_status(conn, ref):
    post = conn.execute(
        "SELECT post_key, message_id, post_id, date_utc, date_msk, text, text_en FROM posts WHERE post_key=? OR post_id=? OR message_id=? LIMIT 1",
        (ref.post_key, ref.post_id, ref.message_id),
    ).fetchone()
    targets = []
    for row in conn.execute(
        "SELECT target, status, external_id, external_ids_json, url, error, updated_at, raw_json FROM post_targets WHERE post_key=? ORDER BY target",
        (ref.post_key,),
    ):
        ids = []
        if row["external_ids_json"]:
            try:
                parsed = json.loads(row["external_ids_json"])
                ids = parsed if isinstance(parsed, list) else []
            except Exception:
                ids = []
        targets.append({
            "target": row["target"],
            "status": row["status"],
            "external_id": row["external_id"],
            "external_ids": ids,
            "url": target_public_url(row["target"], row["external_id"], row["url"]),
            "error": row["error"],
            "updated_at": row["updated_at"],
            "raw": json.loads(row["raw_json"] or "{}") if row["raw_json"] else {},
        })
    metrics = []
    for row in conn.execute(
        "SELECT target, metric_name, value, sampled_at, source, error, raw_json FROM post_metrics WHERE post_key=? ORDER BY target, metric_name",
        (ref.post_key,),
    ):
        metrics.append({
            "target": row["target"],
            "metric_name": row["metric_name"],
            "value": row["value"],
            "sampled_at": row["sampled_at"],
            "sampled_age_seconds": _age_seconds(row["sampled_at"]),
            "source": row["source"],
            "error": row["error"],
            "raw": json.loads(row["raw_json"] or "{}") if row["raw_json"] else {},
        })
    schedule = []
    for row in conn.execute(
        "SELECT target, next_check_at, last_checked_at, check_count, frozen_at, last_error, updated_at FROM metric_schedule WHERE post_key=? ORDER BY target",
        (ref.post_key,),
    ):
        schedule.append(dict(row))
    return {
        "ref": ref.__dict__,
        "post": dict(post) if post else None,
        "targets": targets,
        "metrics": metrics,
        "schedule": schedule,
    }


def cmd_status(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        ref = resolve_publication_ref(conn, args.ref)
        payload = collect_post_status(conn, ref)
        if args.json:
            print(json.dumps(payload, ensure_ascii=False, indent=2))
            return
        post = payload["post"]
        print(f"POST {ref.post_key}")
        print(f"Canonical post_id: {ref.post_id or ''}")
        print(f"Telegram message_id: {ref.message_id or ''}")
        if post:
            print(f"Date UTC: {post['date_utc']}")
            print(f"Date MSK: {post['date_msk']}")
            print(f"RU: {(post['text'] or '')[:120]}")
            print(f"EN: {(post['text_en'] or '')[:120]}")
        print("")
        for row in payload["targets"]:
            suffix = f" ext={row['external_id']}" if row["external_id"] else ""
            parts = ""
            if len(row["external_ids"]) > 1:
                parts = f" parts={len(row['external_ids'])} ids={row['external_ids']}"
            link = f" url={row['url']}" if row["url"] else ""
            error = f" error={row['error']}" if row["error"] else ""
            updated = f" updated={row['updated_at']}" if row["updated_at"] else ""
            print(f"{row['target']}: {row['status']}{link}{suffix}{parts}{error}{updated}")
        if payload["metrics"]:
            print("")
            grouped = {}
            for row in payload["metrics"]:
                sampled = f"@{row['sampled_at']}" if row.get("sampled_at") else ""
                err = f" err={row['error']}" if row.get("error") else ""
                grouped.setdefault(row["target"], []).append(f"{row['metric_name']}={row['value']}{sampled}{err}")
            for target, values in grouped.items():
                print(f"{target}: {', '.join(values)}")
        if payload["schedule"]:
            print("")
            for row in payload["schedule"]:
                frozen = f" frozen={row['frozen_at']}" if row["frozen_at"] else ""
                error = f" error={row['last_error']}" if row["last_error"] else ""
                print(f"schedule {row['target']}: checks={row['check_count']} next={row['next_check_at']}{frozen}{error}")


def cmd_requeue(args):
    result = RepairService(actor_type="postingctl").requeue(args.ref, target=args.target)
    print(json.dumps(result, ensure_ascii=False, indent=2))


def cmd_verify(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        ref = resolve_publication_ref(conn, args.ref)
        rows = conn.execute(
            "SELECT target, status, external_id, external_ids_json, url, error, updated_at FROM post_targets WHERE post_key=? ORDER BY target",
            (ref.post_key,),
        ).fetchall()
    if args.target:
        rows = [row for row in rows if row["target"] == args.target]
    results = [verify_target_record(dict(row)) for row in rows]
    print(json.dumps({"ok": all(item["ok"] for item in results), "post_key": ref.post_key, "results": results}, ensure_ascii=False, indent=2))
    if any(not item["ok"] for item in results):
        raise SystemExit(1)


def cmd_schedule(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        rows = conn.execute(
            """
            SELECT id, post_id, status, scheduled_at, scheduled_en_at, channel_message_id, updated_at
            FROM drafts
            WHERE status IN ('scheduled', 'publishing', 'needs_review')
            ORDER BY COALESCE(scheduled_at, scheduled_en_at, updated_at) ASC, id ASC
            LIMIT ?
            """,
            (args.limit,),
        ).fetchall()
        published_today = conn.execute(
            """
            SELECT COUNT(*) AS count
            FROM drafts
            WHERE status='published'
              AND date(COALESCE(scheduled_at, updated_at)) = date('now')
            """
        ).fetchone()["count"]
    print(f"Published today: {published_today}")
    print("ID\tPOST\tSTATUS\tRU_SLOT\tEN_SLOT\tTG_MSG\tUPDATED")
    for row in rows:
        print(
            "\t".join(
                str(value or "")
                for value in (
                    row["id"],
                    row["post_id"],
                    row["status"],
                    row["scheduled_at"],
                    row["scheduled_en_at"],
                    row["channel_message_id"],
                    row["updated_at"],
                )
            )
        )


def cmd_edit(args):
    result = RepairService(actor_type="postingctl").edit_text(args.message_id, text_ru=args.text_ru, text_en=args.text_en)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    if result.get("ok") and not args.no_site_sync:
        run_checked(["docker", "compose", "exec", "-T", "site-feed", "python3", "/app/collector.py", "sync-bot-source"])


def cmd_media_replace_en(args):
    result = RepairService(actor_type="postingctl").replace_en_media(args.message_id, parse_media(args.json))
    print(json.dumps(result, ensure_ascii=False, indent=2))


def cmd_media_use_ru(args):
    result = RepairService(actor_type="postingctl").replace_en_media(args.message_id, None)
    print(json.dumps(result, ensure_ascii=False, indent=2))


def run_checked(cmd):
    res = subprocess.run(cmd, cwd=str(ROOT), text=True)
    if res.returncode != 0:
        raise SystemExit(res.returncode)


def cmd_metrics(args):
    cmd = ["docker", "exec", "-e", "METRICS_IGNORE_MAINTENANCE_LOCK=1", "alexgetman-posting-app", "python3", "/app/pipeline_metrics.py", "once"]
    paths = get_paths()
    if args.force:
        with connect(paths.pipeline_db) as conn:
            conn.execute("UPDATE metric_schedule SET next_check_at=NULL, frozen_at=NULL")
            conn.commit()
    if paths.pipeline_db.exists():
        with connect(paths.pipeline_db) as conn:
            with maintenance_lock(conn):
                run_checked(cmd)
    else:
        run_checked(cmd)


def cmd_metrics_backfill(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        refs = []
        for raw in args.ref or []:
            refs.append(resolve_publication_ref(conn, raw).post_key)
        targets = split_targets(args.targets)
        if not targets:
            raise SystemExit("no supported metric targets selected")
        rows = build_backfill_plan(conn, targets=targets, refs=refs or None, date_from=args.date_from, date_to=args.date_to)
        payload = {"dry_run": args.dry_run, "targets": targets, "count": len(rows), "sample": rows[:20]}
        if args.dry_run:
            print(json.dumps(payload, ensure_ascii=False, indent=2))
            return
        backup = None
        if not args.no_backup:
            backup = backup_database(paths.pipeline_db)
        with maintenance_lock(conn):
            applied = apply_backfill_plan(conn, rows, reset_counts=args.reset_counts)
            if args.sync:
                cmd_metrics(argparse.Namespace(force=False))
        payload.update({"applied": applied, "backup": str(backup) if backup else None})
        print(json.dumps(payload, ensure_ascii=False, indent=2))


def cmd_alerts_audit(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        payload = audit_alerts(conn)
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def cmd_health(args):
    run_checked([str(ROOT / "scripts" / "health-check")])


def cmd_backup(args):
    run_checked([str(ROOT / "scripts" / "backup-db")])


def cmd_rebuild(args):
    run_checked(["docker", "compose", "up", "-d", "--build", "posting-app", "site-feed"])


def cmd_db_status(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        for row in migration_status(conn):
            state = "applied" if row["applied"] else "pending"
            checksum = "checksum_ok" if row["checksum_ok"] else "checksum_mismatch"
            print(f"{row['migration_id']}\t{state}\t{checksum}\t{row['name']}\t{row['applied_at'] or ''}")


def cmd_db_migrate(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        applied = apply_migrations(conn)
    if not applied:
        print("no pending migrations")
        return
    for row in applied:
        print(f"applied {row['migration_id']}: {row['name']} at {row['applied_at']}")


def cmd_db_verify(args):
    paths = get_paths()
    if not paths.pipeline_db.exists():
        raise SystemExit(f"missing DB: {paths.pipeline_db}")
    with connect(paths.pipeline_db) as conn:
        errors = verify_schema(conn)
    if errors:
        for error in errors:
            print(f"ERROR: {error}")
        raise SystemExit(1)
    print("schema verify ok")


def cmd_limits(args):
    from posting_core.controller.limits import MAX_DRAFT_TEXT_CHARS
    from posting_core.metrics_config import SCHEDULED_TARGETS

    print(f"draft_text_max_chars={MAX_DRAFT_TEXT_CHARS}")
    print("thread_split:")
    print("  threads=480 chars")
    print("  bluesky=300 graphemes")
    print("  mastodon=instance max_characters - 20, fallback 480")
    print("  devto=full article")
    print("scheduled_metric_targets=" + ",".join(SCHEDULED_TARGETS))


def main():
    parser = argparse.ArgumentParser(description="alexgetman-posting operations CLI")
    sub = parser.add_subparsers(dest="cmd", required=True)

    status = sub.add_parser("status")
    status.add_argument("ref", help="post_id, message_id, post:<id>, telegram:<channel>:<id>, or msg:<id>")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=cmd_status)

    requeue = sub.add_parser("requeue")
    requeue.add_argument("ref", help="post_id, message_id, post:<id>, telegram:<channel>:<id>, or msg:<id>")
    requeue.add_argument("--target", choices=ALL_TARGET_IDS)
    requeue.set_defaults(func=cmd_requeue)

    verify = sub.add_parser("verify")
    verify.add_argument("ref", help="post_id, message_id, post:<id>, telegram:<channel>:<id>, or msg:<id>")
    verify.add_argument("--target", choices=ALL_TARGET_IDS)
    verify.set_defaults(func=cmd_verify)

    limits = sub.add_parser("limits", help="show configured publishing limits")
    limits.set_defaults(func=cmd_limits)

    schedule = sub.add_parser("schedule", help="show draft schedule diagnostics")
    schedule.add_argument("--limit", type=int, default=40)
    schedule.set_defaults(func=cmd_schedule)

    edit = sub.add_parser("edit")
    edit.add_argument("message_id", type=int)
    edit.add_argument("--text-ru")
    edit.add_argument("--text-en")
    edit.add_argument("--no-site-sync", action="store_true")
    edit.set_defaults(func=cmd_edit)

    media = sub.add_parser("media")
    media_sub = media.add_subparsers(dest="media_cmd", required=True)
    replace_en = media_sub.add_parser("replace-en")
    replace_en.add_argument("message_id", type=int)
    replace_en.add_argument("--json", required=True)
    replace_en.set_defaults(func=cmd_media_replace_en)
    use_ru = media_sub.add_parser("use-ru-for-en")
    use_ru.add_argument("message_id", type=int)
    use_ru.set_defaults(func=cmd_media_use_ru)

    metrics = sub.add_parser("metrics")
    metrics_sub = metrics.add_subparsers(dest="metrics_cmd", required=True)
    sync = metrics_sub.add_parser("sync")
    sync.add_argument("--force", action="store_true")
    sync.set_defaults(func=cmd_metrics)
    backfill = metrics_sub.add_parser("backfill", help="schedule supported metric targets for one-off backfill")
    backfill.add_argument("--dry-run", action="store_true")
    backfill.add_argument("--targets", help="comma-separated target IDs; defaults to supported scheduled targets")
    backfill.add_argument("--ref", action="append", help="post ref; can be repeated")
    backfill.add_argument("--from", dest="date_from", help="inclusive UTC ISO lower bound")
    backfill.add_argument("--to", dest="date_to", help="inclusive UTC ISO upper bound")
    backfill.add_argument("--reset-counts", action="store_true")
    backfill.add_argument("--no-backup", action="store_true")
    backfill.add_argument("--sync", action="store_true", help="run metrics sync after scheduling")
    backfill.set_defaults(func=cmd_metrics_backfill)

    alerts = sub.add_parser("alerts")
    alerts_sub = alerts.add_subparsers(dest="alerts_cmd", required=True)
    alerts_audit = alerts_sub.add_parser("audit")
    alerts_audit.set_defaults(func=cmd_alerts_audit)

    health = sub.add_parser("health")
    health.set_defaults(func=cmd_health)

    backup = sub.add_parser("backup")
    backup.set_defaults(func=cmd_backup)

    rebuild = sub.add_parser("rebuild")
    rebuild.set_defaults(func=cmd_rebuild)

    db = sub.add_parser("db")
    db_sub = db.add_subparsers(dest="db_cmd", required=True)
    db_status = db_sub.add_parser("status")
    db_status.set_defaults(func=cmd_db_status)
    db_migrate = db_sub.add_parser("migrate")
    db_migrate.set_defaults(func=cmd_db_migrate)
    db_verify = db_sub.add_parser("verify")
    db_verify.set_defaults(func=cmd_db_verify)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
