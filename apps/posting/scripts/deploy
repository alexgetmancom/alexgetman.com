#!/usr/bin/env sh
set -eu

HOST="${HOST:-tw-nl}"
REMOTE_DIR="${REMOTE_DIR:-/opt/alexgetman-posting}"

./scripts/check

ssh "$HOST" "cd '$REMOTE_DIR' && mkdir -p data/backups && test ! -f data/pipeline.db || cp -p data/pipeline.db data/backups/pipeline-predeploy-\$(date -u +%Y%m%dT%H%M%SZ).db"
ssh "$HOST" "cd '$REMOTE_DIR' && test ! -f data/controller.db || mv data/controller.db data/backups/controller-db-retired-\$(date -u +%Y%m%dT%H%M%SZ).db"

rsync -a --delete \
  --exclude='data/' \
  --exclude='bot-api-data/' \
  --exclude='bot-api-temp/' \
  --exclude='secrets.env' \
  --exclude='site-feed.env' \
  --exclude='telegram-bot-api.env' \
  ./ "$HOST:$REMOTE_DIR/"

ssh "$HOST" "cd '$REMOTE_DIR' && ./scripts/postingctl db migrate && ./scripts/postingctl db verify"
ssh "$HOST" "cd '$REMOTE_DIR' && docker compose build posting-app site-feed && docker compose up -d --remove-orphans bot-api posting-app site-feed"
./scripts/smoke
