{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts", "apps/web/server.ts", "apps/web/src/pages/**/*.astro", "apps/web/src/components/**/*.astro"],
      "project": ["apps/web/src/**/*.ts", "apps/web/src/**/*.astro", "scripts/**/*.ts"],
      "ignoreDependencies": ["@mtcute/bun"]
    },
    "apps/backend": {
      "entry": ["tests/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    }
  },
  "ignore": [
    "apps/web/src/utils/home-posts.ts",
    "apps/backend/src/fsUtils.ts",
    "apps/backend/src/operations/dashboard/**",
    "apps/web/src/utils/brand.ts",
    "apps/backend/tests/helpers/db.ts"
  ]
}
