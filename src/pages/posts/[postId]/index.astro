---
import LegacyRedirect from '../../../components/LegacyRedirect.astro';
import { loadFeedItems } from '../../../utils/feed';

export async function getStaticPaths() {
  return loadFeedItems()
    .filter((item: any) => item.post_id)
    .map((item: any) => ({ params: { postId: String(item.post_id) }, props: { item } }));
}

const { item } = Astro.props;
const target = item?.has_en && item?.slug_en
  ? `/${item.post_id}/${item.slug_en}/`
  : `/ru/${item.post_id}/${item.slug_ru}/`;
---

<LegacyRedirect target={target} title="Post URL moved" />
