---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';
import { loadFeedItems } from '../utils/feed';
import {
  categoryLabel,
  categorySlugFromBadge,
  excerptAfterTitle,
  formatDate,
  formatRelativeTime,
  getFirstSentence,
  getSmartBadge,
  truncateText
} from '../utils/helpers';

const feedItems = loadFeedItems();

function postImage(item) {
  const media = Array.isArray(item.media_en) && item.media_en.length > 0
    ? item.media_en
    : (Array.isArray(item.media) ? item.media : []);
  const imageMedia = media.find((mediaItem) => mediaItem?.type !== 'video' && mediaItem?.path);
  return item.image_en || imageMedia?.path || item.image || null;
}

function toEnglishPost(item) {
  const id = item.post_id;
  const text = item.text_en || item.text || "";
  const title = getFirstSentence(text) || `Post ${id}`;
  const badge = getSmartBadge(item.text || text);
  const categorySlug = categorySlugFromBadge(badge);
  return {
    id,
    url: `/${id}/${item.slug_en}/`,
    title,
    excerpt: excerptAfterTitle(text, title, 180),
    date: item.date,
    relativeDate: formatRelativeTime(item.date, 'en'),
    image: postImage(item),
    views: Number(item.views || 0),
    categorySlug,
    category: categoryLabel(categorySlug, 'en'),
  };
}

const englishPosts = feedItems
  .filter((item) => item.has_en && item.text_en && item.post_id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map(toEnglishPost);

const leadPost = englishPosts[0] || null;
const latestEnglishPosts = englishPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...englishPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => (b.views - a.views) || (new Date(b.date).getTime() - new Date(a.date).getTime()))
  .slice(0, 5);
const topicStats = Array.from(
  englishPosts.reduce((map, post) => {
    const current = map.get(post.categorySlug) || { slug: post.categorySlug, label: post.category, count: 0 };
    current.count += 1;
    map.set(post.categorySlug, current);
    return map;
  }, new Map()).values()
).sort((a, b) => b.count - a.count);

const title = "Alex Getman | AI, automation and self-hosted systems";
const description = "English hub for Alex Getman: AI news, automation, developer tools, self-hosted systems and public projects.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      "name": "Alex Getman",
      "alternateName": "Алексей Гетманец",
      "url": "https://alexgetman.com/",
      "image": "https://alexgetman.com/avatar.png",
      "sameAs": [
        "https://t.me/alexgetmancom",
        "https://www.threads.net/@alexgetmanco",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      "url": "https://alexgetman.com/",
      "name": "Alex Getman",
      "description": description,
      "inLanguage": "en-US",
      "publisher": { "@id": "https://alexgetman.com/#person" }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/#home",
      "url": "https://alexgetman.com/",
      "name": title,
      "description": description,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://alexgetman.com/#website" }
    }
  ]
});

function formatDate(value) {
  if (!value) return "";
  try {
    return new Intl.DateTimeFormat("en-GB", {
      timeZone: "Europe/Moscow",
      day: "2-digit",
      month: "short",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).format(new Date(value));
  } catch (e) {
    return value;
  }
}
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/"
  lang="en"
  siteName="Alex Getman"
  rssHref="/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
>
  <main class="home-page">
    <section class="hero" aria-labelledby="home-title">
      <p class="hero__eyebrow">alexgetmancom</p>
      <h1 class="hero__title" id="home-title">AI, automation and self-hosted systems</h1>
      <p class="hero__text">
        I track practical AI product changes, build automation around publishing workflows, and document public projects across developer tools, infrastructure and media systems.
      </p>
      <div class="hero__actions">
        <a href="/ru/" class="home-link">Russian feed</a>
        <a href="/search/" class="home-link">Search</a>
        <a href="/archive/" class="home-link">Archive</a>
        <a href="/projects/" class="home-link">Projects</a>
        <a href="/contacts/" class="home-link">Contacts</a>
      </div>
    </section>

    {leadPost ? (
      <section class="lead-section" aria-labelledby="lead-title">
        <a href={leadPost.url} class="lead-card">
          <div class="lead-card__media">
            {leadPost.image ? (
              <img src={`/${leadPost.image}`} alt="" loading="eager" decoding="async" sizes="(max-width: 760px) 100vw, 680px" />
            ) : (
              <span>{leadPost.category}</span>
            )}
          </div>
          <div class="lead-card__body">
            <span class="pill">{leadPost.category}</span>
            <h2 id="lead-title">{leadPost.title}</h2>
            <p>{leadPost.excerpt}</p>
            <small>{leadPost.relativeDate || `${formatDate(leadPost.date)} MSK`}</small>
          </div>
        </a>
      </section>
    ) : (
      <p class="empty">English posts will appear here after publication approval.</p>
    )}

    <div class="content-grid">
      <section class="section" aria-labelledby="posts-title">
        <div class="section__header">
          <h2 class="section__title" id="posts-title">Latest English posts</h2>
          <a href="/archive/" class="section__link">Archive</a>
        </div>
        <div class="post-list">
          {latestEnglishPosts.map((post) => (
            <a href={post.url} class="post-row">
              <span class="post-row__date">{post.relativeDate || `${formatDate(post.date)} MSK`}</span>
              <strong>{post.title}</strong>
              <span>{post.excerpt}</span>
            </a>
          ))}
        </div>
      </section>

      <aside class="home-sidebar" aria-label="Homepage side sections">
        <section class="panel" aria-labelledby="trending-title">
          <div class="section__header">
            <h2 class="section__title" id="trending-title">Trending</h2>
            <a href="/search/" class="section__link">Search</a>
          </div>
          <div class="compact-list">
            {trendingPosts.map((post) => (
              <a href={post.url} class="compact-row">
                <span>{post.category}</span>
                <strong>{truncateText(post.title, 82)}</strong>
              </a>
            ))}
          </div>
        </section>

        <section class="panel" aria-labelledby="topics-title">
          <h2 class="section__title" id="topics-title">Topics</h2>
          <div class="topic-grid">
            {topicStats.map((topic) => (
              <a href={`/category/${topic.slug}/`} class="topic-pill">
                <span>{topic.label}</span>
                <small>{topic.count}</small>
              </a>
            ))}
          </div>
        </section>

        <section class="panel" aria-labelledby="projects-title">
          <div class="section__header">
            <h2 class="section__title" id="projects-title">Projects</h2>
            <a href="/projects/" class="section__link">All</a>
          </div>
          <div class="project-list">
            {projects.slice(0, 3).map((project) => (
              <a href={project.url} class="project-row" target="_blank" rel="noopener noreferrer">
                <span>{project.kind}</span>
                <strong>{project.name}</strong>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .home-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
    min-width: 0;
  }

  .hero {
    padding: 2rem 0 2.5rem;
    min-width: 0;
  }

  .hero__eyebrow {
    margin: 0 0 0.6rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .hero__title {
    margin: 0;
    max-width: 900px;
    font-size: clamp(2.5rem, 5vw, 5rem);
    line-height: 1.02;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero__text {
    max-width: 760px;
    margin: 1rem 0 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .hero__actions,
  .section__header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__actions {
    margin-top: 1.25rem;
  }

  .home-link,
  .section__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-main);
    font-weight: 700;
  }

  .home-link:hover,
  .section__link:hover {
    color: var(--text-header);
    border-color: var(--border-hover);
    background: var(--accent-glow);
  }

  .section {
    margin-top: 1.4rem;
  }

  .lead-section {
    margin-top: 0.5rem;
  }

  .lead-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.2rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-main);
  }

  .lead-card__media {
    min-height: 260px;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(240, 68, 101, 0.12), rgba(255, 255, 255, 0.03));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-weight: 800;
  }

  .lead-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lead-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.8rem;
  }

  .lead-card h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3.4vw, 3rem);
    line-height: 1.08;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .lead-card p {
    margin: 0;
    color: var(--text-secondary);
  }

  .lead-card small {
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .pill {
    width: fit-content;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.75fr) minmax(280px, 0.8fr);
    gap: 1.3rem;
    align-items: start;
    margin-top: 1.4rem;
  }

  .content-grid .section {
    margin-top: 0;
  }

  .home-sidebar {
    display: grid;
    gap: 0.9rem;
  }

  .panel {
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    min-width: 0;
  }

  .section__header {
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .section__title {
    margin: 0;
    font-size: 1.15rem;
  }

  .post-list,
  .compact-list,
  .project-list {
    display: grid;
    gap: 0.75rem;
  }

  .post-row {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    min-width: 0;
  }

  .post-row span,
  .compact-row span,
  .project-row span {
    color: var(--text-secondary);
  }

  .post-row__date {
    font-size: 0.82rem;
  }

  .compact-row,
  .project-row {
    display: grid;
    gap: 0.2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-main);
    min-width: 0;
  }

  .compact-row:last-child,
  .project-row:last-child {
    border-bottom: 0;
  }

  .compact-row strong,
  .project-row strong {
    color: var(--text-header);
    font-size: 0.92rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .compact-row span,
  .project-row span {
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .topic-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }

  .topic-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-main);
    font-size: 0.84rem;
  }

  .topic-pill small {
    color: var(--text-muted);
  }

  .empty {
    margin: 0;
    color: var(--text-secondary);
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 1rem;
    }

    .lead-card,
    .content-grid {
      grid-template-columns: 1fr;
    }
    .lead-card__media {
      min-height: 180px;
    }
  }
</style>
