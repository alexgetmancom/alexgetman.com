---
import { truncateText } from '../../utils/helpers';
import type { HomePost, StoryUi } from './types';

interface Props {
  posts: HomePost[];
  ui: StoryUi;
}

const { posts, ui } = Astro.props;
---

<nav class="story-rail" aria-label={ui.storyRail}>
  {posts.map((post, index) => (
    <a
      href={post.url}
      class={`rail-card${index === 0 ? ' is-active' : ''}${post.image ? '' : ' rail-card--no-image'}`}
      data-story-index={index}
      data-media-src={post.image ? `/${post.image}` : undefined}
      data-media-type={post.mediaType || undefined}
      data-media-fallback={post.fallbackImage ? `/${post.fallbackImage}` : undefined}
      data-media-srcset={post.imageSrcSet || undefined}
    >
      <span class="rail-card__media" aria-hidden="true">
        {post.image && index < 7 ? (
          post.mediaType === 'video' ? (
            post.fallbackImage ? (
              <img
                src={`/${post.fallbackImage}`}
                alt=""
                loading={index < 4 ? 'eager' : 'lazy'}
                decoding="async"
                sizes="72px"
              />
            ) : (
              <video
                src={`/${post.image}#t=0.001`}
                muted
                playsinline
                preload="metadata"
              ></video>
            )
          ) : (
            <img
              src={`/${post.image}`}
              srcset={post.imageSrcSet}
              alt=""
              loading={index < 4 ? 'eager' : 'lazy'}
              decoding="async"
              sizes="72px"
              data-fallback-src={post.fallbackImage ? `/${post.fallbackImage}` : undefined}
            />
          )
        ) : (
          <span>{post.category}</span>
        )}
      </span>
      <span class="rail-card__shade"></span>
      <span class="rail-card__text">
        <strong>{truncateText(post.title, 62)}</strong>
      </span>
      <span class="rail-card__progress" data-story-progress-bar>
        <i></i>
      </span>
    </a>
  ))}
</nav>
