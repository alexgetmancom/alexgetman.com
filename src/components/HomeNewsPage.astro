---
import '../styles/home-news-page.css';
import StoryContext from './home-news/StoryContext.astro';
import StoryRail from './home-news/StoryRail.astro';
import StoryVisual from './home-news/StoryVisual.astro';
import { metricValue, paragraphsFor } from './home-news/storyHelpers';
import type { HomeLabels, HomePost, Project, TopicStat } from './home-news/types';

interface Props {
  posts: HomePost[];
  latestPosts: HomePost[];
  trendingPosts: HomePost[];
  topicStats: TopicStat[];
  projects: Project[];
  labels: HomeLabels;
  locale: 'en' | 'ru';
  categoryBasePath: string;
  initialPostId?: number | string;
  initialPaused?: boolean;
}

const {
  posts,
  labels,
  locale,
  initialPostId,
  initialPaused = false,
} = Astro.props;

const selectedPost = initialPostId
  ? posts.find((post) => String(post.id) === String(initialPostId))
  : null;
const storyPosts = selectedPost
  ? [selectedPost, ...posts.filter((post) => String(post.id) !== String(selectedPost.id)).slice(0, 4)]
  : posts.slice(0, 5);
const activePost = storyPosts[0] || null;
const isRu = locale === 'ru';
const ui = {
  storyLabel: isRu ? 'Новостной плеер' : 'AI news player',
  postTab: isRu ? 'Пост' : 'Post',
  discussionTab: isRu ? 'Обсуждение' : 'Discussion',
  sourcesTab: isRu ? 'Источники' : 'Sources',
  previous: isRu ? 'Предыдущая новость' : 'Previous story',
  next: isRu ? 'Следующая новость' : 'Next story',
  discuss: isRu ? 'Обсудить' : 'Discuss',
  share: isRu ? 'Поделиться' : 'Share',
  readMore: isRu ? 'Читать дальше' : 'Read more',
  collapse: isRu ? 'Свернуть' : 'Collapse',
  openPost: isRu ? 'Открыть пост' : 'Open post',
  mute: isRu ? 'Звук' : 'Audio',
  muted: isRu ? 'Звук выкл' : 'Muted',
  storyRail: isRu ? 'Выбор новостей' : 'Story rail',
  noDiscussion: isRu ? 'Обсуждения подключим здесь. Пока можно открыть пост и поделиться ссылкой.' : 'Discussion will live here. For now, open the post or share the link.',
  sourcesHint: isRu ? 'Источники и социальные копии появятся здесь, когда они есть у поста.' : 'Sources and social copies will appear here when a post has them.',
  backToPost: isRu ? 'К посту' : 'Back to post',
  copied: isRu ? 'Скопировано' : 'Copied',
  views: isRu ? 'просмотров' : 'views',
  replies: isRu ? 'ответов' : 'replies',
  reactions: isRu ? 'реакций' : 'reactions',
};

---

<main class="home-page">
  {activePost ? (
    <section class="story-player" aria-label={ui.storyLabel} data-story-player data-initial-paused={initialPaused ? 'true' : 'false'}>
      <div class="story-player__main">
        <div class="story-rail-container">
          <StoryRail posts={storyPosts} ui={ui} />
        </div>
        <StoryVisual activePost={activePost} posts={storyPosts} ui={ui} />
        <StoryContext activePost={activePost} paragraphs={paragraphsFor(activePost)} ui={ui} />
      </div>

      <script type="application/json" data-story-payload set:html={JSON.stringify({
        ui,
        posts: storyPosts.map((post) => ({
          id: post.id,
          url: post.url,
          title: post.title,
          body: paragraphsFor(post),
          excerpt: post.excerpt,
          date: post.date,
          relativeDate: post.relativeDate,
          image: post.image ? `/${post.image}` : null,
          fallbackImage: post.fallbackImage ? `/${post.fallbackImage}` : null,
          mediaType: post.mediaType || null,
          audioUrl: post.audioUrl || null,
          spotifyUrl: post.spotifyUrl || null,
          imageSrcSet: post.imageSrcSet || '',
          views: metricValue(post.views),
          category: post.category,
          readMore: ui.readMore,
          collapse: ui.collapse,
        })),
        initialPaused,
        giscus: {
          repo: 'alexgetmancom/alexgetman.com',
          repoId: 'R_kgDOSJwPnQ',
          category: 'Announcements',
          categoryId: 'DIC_kwDOSJwPnc4C-S2f',
          lang: isRu ? 'ru' : 'en',
        },
      })}></script>
    </section>
  ) : (
    <p class="empty">{labels.empty}</p>
  )}
</main>

<script src="../scripts/home-news-player.js"></script>
